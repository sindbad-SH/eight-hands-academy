---
// COMMUNITY — reskin of the reference Community page, structure VERIFIED by live Chrome audit of
// aiglon.ch/community (2026-06-05). Reference shape: LEFT-aligned H1, an intro with a LAYERED photo pair +
// ▶ pill (left) + highlight heading + copy + ClaimRotator (right), then a centered-title photo hub of
// community facets, no closing CTA. Re-skinned for the Qi-House; hub routes to our real community sub-pages.
import Base from '../../layouts/Base.astro';
import SectionSubnav from '../../components/SectionSubnav.astro';
import GoldArrowLink from '../../components/GoldArrowLink.astro';
import ParallaxPhoto from '../../components/ParallaxPhoto.astro';
import ClaimRotator from '../../components/ClaimRotator.astro';
import PhotoNavCard from '../../components/PhotoNavCard.astro';

const subnav: [string, string][] = [
  ['Participation in Practice', '/community'],
  ['Summer Academy', '/community/summer-academy'],
  ['Instructor Development', '/community/instructor-development'],
  ['Alumni', '/community/alumni'],
  ['Community Impact', '/community/impact'],
  ['Events & Gatherings', '/community/events'],
];

const claims: [string, string][] = [
  ['Growth Is Shared', 'Confidence, focus, and accountability develop faster among people pursuing the same outcomes together.'],
  ['Parents Are Included', 'Families are kept informed and involved, so progress at the Qi-House is reinforced at home.'],
  ['Participation Is the Method', 'Belonging is earned the way capability is — by showing up, contributing, and supporting others.'],
  ['Leadership in Practice', 'Advanced students apply what they have learned by guiding newer ones — leadership as a living skill.'],
];

const hub: [string, string, string, string][] = [
  ['Summer Academy', '/community/summer-academy', '[IMAGE — intensive seasonal practice, outdoors/candid · 4:3 · 760×570px]', '/img/service-1.jpg'],
  ['Instructor Development', '/community/instructor-development', '[IMAGE — senior student teaching / leading a group · 4:3 · 760×570px]', '/img/mentoring-1.jpg'],
  ['Alumni', '/community/alumni', '[IMAGE — former students returned, across generations · 4:3 · 760×570px]', '/img/member-1.jpg'],
  ['Community Impact', '/community/impact', '[IMAGE — service / contribution beyond the studio · 4:3 · 760×570px]', '/img/service-1.jpg'],
  ['Events & Gatherings', '/community/events', '[IMAGE — a community gathering / demonstration · 4:3 · 760×570px]', '/img/community-1.jpg'],
  ['Get Involved', '/admissions#visit', '[IMAGE — a newcomer welcomed onto the floor · 4:3 · 760×570px]', '/img/instruction-2.jpg'],
];
---
<Base home title="Community — The Qi-House" description="Confidence, discipline, and focus develop fastest in community — among students, instructors, and families pursuing the same outcomes together.">
  <SectionSubnav items={subnav} active="/community" label="Community section" />

  <section class="bg-stone">
    <div class="container-content py-section-sm lg:py-section">
      <h1 class="text-4xl lg:text-5xl text-navy mb-12 lg:mb-16">Community</h1>

      <div class="grid lg:grid-cols-2 gap-14 lg:gap-20 items-start">
        <div class="reveal lg:order-2">
          <div class="relative min-h-[420px] lg:min-h-[540px]">
            <ParallaxPhoto
              img="/img/community-1.jpg"
              alt="[IMAGE — a student supported by peers / an instructor mid-encouragement, candid (primary) · PORTRAIT 4:5 · 1000×1250px]"
              frameClass="aspect-[4/5] w-[78%]"
              parallax={-104}
              innerClass="!text-xs"
            />
            <ParallaxPhoto
              img="/img/group-2.jpg"
              alt="[IMAGE — parents and members at a gathering / demonstration, engaged (secondary) · LANDSCAPE 4:3 · 900×675px]"
              frameClass="absolute -bottom-6 right-0 lg:-right-10 w-[58%] aspect-[4/3] z-20 ring-[10px] ring-stone"
              parallax={-100}
              innerClass="!p-3 !text-[10px]"
            />
          </div>
          <div class="flex justify-start mt-8">
            <button class="group inline-flex items-center gap-3 rounded-full border border-navy/20 bg-white/50 hover:bg-white pl-1.5 pr-5 py-1.5 transition-colors" aria-label="Play: A Living Practice">
              <span class="w-9 h-9 rounded-full bg-red flex items-center justify-center shrink-0 transition-transform duration-200 group-hover:scale-110">
                <svg width="10" height="12" viewBox="0 0 10 12" class="text-stone ml-0.5" fill="currentColor"><polygon points="0,0 10,6 0,12" /></svg>
              </span>
              <span class="font-accent text-sm tracking-wide text-navy">A Living Practice</span>
            </button>
          </div>
        </div>

        <div class="reveal lg:order-1">
          <p class="font-accent uppercase tracking-[0.14em] text-xl lg:text-2xl text-navy mb-7 inline-flex flex-wrap items-center gap-x-2.5 gap-y-1">
            <span class="bg-red text-stone px-2 py-0.5">Community</span><span>Strengthens Development</span>
          </p>
          <p class="text-slate/90 leading-relaxed mb-5">Confidence, discipline, and focus are not built in isolation. They develop through meaningful interaction with others—students who train alongside one another, instructors who provide guidance and accountability, and families who support growth beyond the academy.</p>
          <p class="text-slate/90 leading-relaxed mb-5">The Qi-House is more than a place to learn skills. It is a community of participation where individuals are encouraged to contribute, support one another, and take responsibility for their role in the learning environment. Students benefit not only from instruction, but from the shared experience of working toward meaningful goals together.</p>
          <p class="text-slate/90 leading-relaxed mb-8">Around the daily practice of development exists a wider network of support: families who reinforce positive habits, alumni who carry their learning into the world, and community members who choose to lead through service and stewardship. Lasting growth occurs when individuals are connected to something larger than themselves, and when learning becomes a shared responsibility rather than a solitary pursuit.</p>
          <GoldArrowLink href="/community/impact" text="How We Serve" class="mb-10" />
          <ClaimRotator items={claims} dark={false} label="What the community is built on" />
        </div>
      </div>
    </div>
  </section>

  <!-- Photo hub: community facets (centered titles) → real sub-pages -->
  <section class="bg-stone-200">
    <div class="container-content py-section-sm lg:py-section">
      <div class="text-center max-w-2xl mx-auto mb-12 reveal">
        <h2 class="text-3xl lg:text-4xl">Ways to Take Part</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3">
        {hub.map(([label, href, alt, img]) => (
          <div class="reveal"><PhotoNavCard label={label} href={href} alt={alt} img={img} center /></div>
        ))}
      </div>
    </div>
  </section>
</Base>
