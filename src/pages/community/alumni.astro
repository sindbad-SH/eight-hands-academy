---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import SectionSubnav from '../../components/SectionSubnav.astro';
import { communitySubnav } from '../../data/nav';
import Cta from '../../components/Cta.astro';
import { withBase } from '../../data/site';

// 3 distinct images (Jeanette 2026-06-08: alumni had her bag photo twice → de-duped; one bag photo
// swapped for the "kiddo" she sent). member-1 = the kept bag photo, member-2 = students training,
// youth-1 = the young student she emailed (IMG_20260607_211528.jpg, optimized).
const alumPhotos = ['/img/member-1.jpg', '/img/member-2.jpg', '/img/youth-1.jpg'];
---
<Base title="Alumni — Eight Hands Martial Arts Academy">
  <SectionSubnav items={communitySubnav} active="/community/alumni" label="Community section" />
  <PageHeader
    eyebrow="Community"
    title="Alumni"
    subtitle="Students who carry the confidence, discipline, and self-governance built at Eight Hands into the world."
  />
  <section class="bg-stone">
    <div class="container-content py-section-sm lg:py-section">
      <div class="grid md:grid-cols-3 gap-6">
        {Array.from({ length: 3 }).map((_, i) => (
          <figure class="reveal bg-white border border-navy/10 rounded-sm overflow-hidden">
            <img src={withBase(alumPhotos[i % alumPhotos.length])} alt="Eight Hands member" loading="lazy" class="aspect-[3/4] !border-0 !rounded-none w-full object-cover object-top" />
            <figcaption class="p-6">
              <blockquote class="text-slate/90 italic">[ALUMNI STORY {i + 1}: growth-arc, in their words — never fabricated]</blockquote>
              <p class="eyebrow !text-slate-400 mt-4">[Name · Year / Path]</p>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
  <Cta />
</Base>
