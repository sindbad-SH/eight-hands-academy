---
import Base from '../../layouts/Base.astro';
import SectionSubnav from '../../components/SectionSubnav.astro';
import GoldArrowLink from '../../components/GoldArrowLink.astro';
import ParallaxPhoto from '../../components/ParallaxPhoto.astro';
import ClaimRotator from '../../components/ClaimRotator.astro';
import PhotoNavCard from '../../components/PhotoNavCard.astro';
import { aboutSubnav } from '../../data/nav';

// Section sub-nav lives in data/nav.ts (aboutSubnav) so every About page stays in sync.

// Rotating claim card — outcomes-led, real brand facts only (no fabrication). Maps the reference's institutional claims.
const claims: [string, string][] = [
  ['Confidence & Self-Governance', 'Students learn to govern themselves first — clearly and steadily, on their own terms.'],
  ['Discipline, Focus, Resilience', 'Capability is developed, not awarded — built through study that demands the whole person.'],
  ['An Education, Not a Belt', 'Martial arts is the medium. The development of the individual is the work.'],
  ['Mentorship at the Center', 'Assessment, guidance, and accountability — the relationship that carries each student forward.'],
];

// Photo-button hub — one image card per About sub-page (the reference's About card grid).
const navCards: [string, string, string, string][] = [
  ["Director's Welcome", '/about/directors-welcome', '[IMAGE — director instructing, candid · 4:3 · 960×720px]', '/img/instruction-1.jpg'],
  ['The Qi-House Ethos', '/about/ethos', '[IMAGE — ethos / philosophy motif, calm + considered · 4:3 · 960×720px]', '/img/reflection-1.jpg'],
  ['A Message to Students', '/about/founder', '[IMAGE — instructor with students · 4:3 · 960×720px]', '/img/mentoring-2.jpg'],
  ['Governance', '/about/governance', '[IMAGE — standards / stewardship, architectural · 4:3 · 960×720px]', '/img/environment-2.jpg'],
  ['Leadership', '/about/leadership', '[IMAGE — instructors / mentors, candid · 4:3 · 960×720px]', '/img/group-2.jpg'],
  ['Stewardship & Legacy', '/about/stewardship', '[IMAGE — continuity / legacy across generations · 4:3 · 960×720px]', '/img/community-1.jpg'],
];
---
<Base home title="About — The Qi-House" description="An educational institution whose medium is martial arts.">
  <!-- Section sub-nav directly under the navy header (reference: the About-section local nav) -->
  <SectionSubnav items={aboutSubnav} active="/about" label="About section" />

  <!-- White content body (navy header + footer are the chrome; this interior page's body is light) -->
  <section class="bg-stone">
    <div class="container-content py-section-sm lg:py-section">
      <h1 class="text-center text-4xl lg:text-5xl text-navy mb-14 lg:mb-20">About the Qi-House</h1>

      <!-- Intro (mirrored R→L): RIGHT layered photo pair + ▶ pill · LEFT eyebrow + copy + link + rotating claim card -->
      <div class="grid lg:grid-cols-2 gap-14 lg:gap-20 items-start">
        <div class="reveal lg:order-2">
          <div class="relative min-h-[300px] lg:min-h-[400px]">
            <ParallaxPhoto
              img="/img/instruction-2.jpg"
              alt="[IMAGE — student mid-practice, focused and composed (primary) · LANDSCAPE 4:3 · 1000×750px · development, self-governance]"
              frameClass="aspect-[4/3] w-[88%]"
              parallax={-104}
              innerClass="!text-xs"
            />
            <ParallaxPhoto
              img="/img/exterior-wide.jpg"
              alt="[IMAGE — origins / archival (secondary, B&W) · LANDSCAPE 4:3 · 900×675px]"
              frameClass="absolute -bottom-6 right-0 lg:-right-10 w-[58%] aspect-[4/3] grayscale z-20 ring-[10px] ring-stone"
              parallax={-100}
              innerClass="!p-3 !text-[10px]"
            />
          </div>
          <div class="flex justify-start mt-8">
            <button class="group inline-flex items-center gap-3 rounded-full border border-navy/20 bg-white/50 hover:bg-white pl-1.5 pr-5 py-1.5 transition-colors" aria-label="Play: The Practice in Motion">
              <span class="w-9 h-9 rounded-full bg-red flex items-center justify-center shrink-0 transition-transform duration-200 group-hover:scale-110">
                <svg width="10" height="12" viewBox="0 0 10 12" class="text-stone ml-0.5" fill="currentColor"><polygon points="0,0 10,6 0,12" /></svg>
              </span>
              <span class="font-accent text-sm tracking-wide text-navy">The Practice in Motion</span>
            </button>
          </div>
        </div>

        <div class="reveal lg:order-1">
          <p class="font-accent uppercase tracking-[0.14em] text-base lg:text-lg text-navy/85 mb-6 flex flex-wrap items-center gap-x-2.5 gap-y-1">
            <span class="bg-red text-stone px-2 py-0.5">Developing</span> the Individual
          </p>
          <p class="text-slate/90 leading-relaxed mb-8">
            Eight Hands is an educational institution whose medium is martial arts. The work is to build the
            confidence, discipline, focus, and self-awareness an individual needs to govern themselves — clearly,
            steadily, and on their own terms — before they set out to influence the world around them.
          </p>
          <p class="text-slate/90 leading-relaxed mb-8">
            We teach that capability is developed, not awarded. Through study that draws mind, body, and
            discernment into balance, students learn to communicate with intent, lead with accountability, and
            meet challenge with resilience. The same education serves parents seeking it for their children,
            adults pursuing it for themselves, and students ready to go further.
          </p>
          <GoldArrowLink href="/about/ethos" text="How We Define Self-Governance" class="mb-10" />
          <ClaimRotator items={claims} dark={false} label="What defines the academy" />
        </div>
      </div>

      <!-- Photo-button hub: image cards to each About sub-page (flush grid, image + title overlay) -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 mt-20 lg:mt-28">
        {navCards.map(([label, href, alt, img]) => (
          <div class="reveal"><PhotoNavCard label={label} href={href} alt={alt} img={img} /></div>
        ))}
      </div>
    </div>
  </section>
</Base>
