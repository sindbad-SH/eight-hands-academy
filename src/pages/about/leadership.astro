---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import Cta from '../../components/Cta.astro';

// Real academy team (client-supplied, Jeanette 2026-06-06). Portraits remain placeholders until photos arrive.
const team = [
  { name: 'Dr. Kasemir, Kyoshi', role: 'Director · Head Instructor', bio: 'Guides the academy’s educational vision, curriculum, and instructional standards while helping students develop the habits and capabilities that support lifelong growth.' },
  { name: 'Sang Nguyen', role: 'Director of Operations', bio: 'Supports the daily operations of the academy, helping ensure students and families receive a consistent, professional, and welcoming experience.' },
  { name: 'Cole Wilson', role: 'Assistant Instructor', bio: 'Supports student development through instruction, mentorship, and positive leadership, helping create an environment where participation and progress are encouraged.' },
  { name: 'Juan Gurule', role: 'Assistant Instructor', bio: 'Assists in training and student support while helping reinforce the values of accountability, respect, and continuous improvement throughout the academy.' },
];
---
<Base title="Leadership — Eight Hands Martial Arts Academy">
  <PageHeader eyebrow="About" title="Leadership" subtitle="The instructors and leaders who guide students toward confidence, discipline, and self-governance." />
  <section class="bg-stone">
    <div class="container-content py-section-sm lg:py-section">
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {team.map((m) => (
          <div class="reveal text-center">
            <div class="ph aspect-square mb-4">[PORTRAIT: {m.name} — dignified, candid]</div>
            <div class="font-display text-xl text-navy">{m.name}</div>
            <div class="eyebrow !text-slate-400 mt-1">{m.role}</div>
            <p class="text-sm text-slate/90 mt-3">{m.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <Cta />
</Base>
