---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import Cta from '../../components/Cta.astro';

const beliefs = [
  ['The individual', 'develops through participation.'],
  ['The community', 'develops through contribution.'],
  ['The institution', 'develops through stewardship.'],
];
---
<Base title="Stewardship & Legacy — The Qi-House">
  <PageHeader
    eyebrow="About"
    title="Stewardship & Legacy"
    subtitle="Legacy emerges naturally when participation, contribution, and stewardship remain aligned."
  />
  <section class="bg-stone">
    <div class="container-content py-section-sm lg:py-section">
      <div class="grid md:grid-cols-3 gap-6 mb-14">
        {beliefs.map(([who, what]) => (
          <div class="reveal bg-white border border-navy/10 rounded-sm p-8 text-center">
            <p class="font-display text-2xl text-navy mb-2">{who}</p>
            <p class="text-slate/90">{what}</p>
          </div>
        ))}
      </div>
      <div class="max-w-3xl mx-auto text-center reveal">
        <p class="text-lg text-slate/90">[COPY: how the academy thinks about legacy — building future leaders,
          mentors, and stewards; leading with "How can we serve?" rather than "How can you support us?"]</p>
      </div>
    </div>
  </section>
  <Cta />
</Base>
