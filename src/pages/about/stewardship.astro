---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import SectionSubnav from '../../components/SectionSubnav.astro';
import { aboutSubnav } from '../../data/nav';
import Cta from '../../components/Cta.astro';

const beliefs = [
  ['The individual', 'develops through participation.'],
  ['The community', 'develops through contribution.'],
  ['The institution', 'develops through stewardship.'],
];
---
<Base title="Stewardship & Legacy — Eight Hands Martial Arts Academy">
  <SectionSubnav items={aboutSubnav} active="/about/stewardship" label="About section" />
  <PageHeader
    eyebrow="About"
    title="Stewardship & Legacy"
    subtitle="Lasting confidence, discipline, and leadership take root when participation, contribution, and stewardship stay aligned."
  />
  <section class="bg-stone">
    <div class="container-content py-section-sm lg:py-section">
      <div class="grid md:grid-cols-3 gap-6 mb-14">
        {beliefs.map(([who, what]) => (
          <div class="reveal bg-white border border-navy/10 rounded-sm p-8 text-center">
            <p class="font-display text-2xl text-navy mb-2">{who}</p>
            <p class="text-slate/90">{what}</p>
          </div>
        ))}
      </div>
      <div class="max-w-3xl mx-auto reveal space-y-5 text-slate/90">
        <p class="text-lg">Eight Hands measures legacy by the leaders, mentors, and stewards it helps
          form — students who learn to govern themselves and then serve the people around them. The work is guided by a
          single question: “How can we serve?” rather than “How can you support us?”</p>
        <p>Our long-term vision extends beyond the training floor. Every student who develops greater confidence, discipline, responsibility, and leadership has the potential to positively influence their family, workplace, community, and future generations. In this way, the impact of education continues long after a class has ended.</p>
        <p>Stewardship means caring for something in a way that allows it to grow and benefit others. We seek to cultivate students who not only pursue their own development, but who also contribute to the development of those around them. The strongest legacy any institution can leave is a community of capable individuals who choose to serve, lead, and participate responsibly wherever life takes them.</p>
      </div>
    </div>
  </section>
  <Cta />
</Base>
