---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import Cta from '../../components/Cta.astro';

const background = [
  'Martial Arts Since 1992',
  'Military Service',
  'Business Leadership',
  'Operations & Finance',
  'Educational Design',
  'Parapsychology',
  'Theocentric Psychology',
  'Political Science',
  'Communication',
  'Philosophy',
  'Operational Leadership',
];
---
<Base title="Founder & History — The Qi-House">
  <PageHeader eyebrow="About" title="Founder & History" subtitle="An educator, mentor, researcher, builder, and steward." />

  <section class="bg-stone">
    <div class="container-content py-section-sm lg:py-section grid lg:grid-cols-[1fr_1.4fr] gap-12 items-start">
      <div class="reveal">
        <div class="ph aspect-[3/4] mb-4">[PORTRAIT: founder — dignified, candid, not posed]</div>
      </div>
      <div class="reveal">
        <p class="text-lg text-slate/90 mb-5">
          [COPY: founder narrative — the path into martial arts since 1992, and the decision to build an
          educational institution whose medium is martial arts. Educator and steward, never guru or
          celebrity. 3–4 paragraphs.]
        </p>
        <p class="text-slate/90 mb-8">
          [COPY: the philosophy that became the Qi-House — self-governance, participation, and the
          development of capable participants rather than merely skilled practitioners.]
        </p>
        <div class="border-t border-navy/10 pt-6">
          <p class="font-display text-2xl text-navy italic">[Founder Name]</p>
          <p class="eyebrow !text-slate-400 mt-1">Founder · The Qi-House</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-stone-200">
    <div class="container-content py-section-sm lg:py-section">
      <p class="eyebrow mb-8 text-center reveal">A Multidisciplinary Foundation</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 max-w-4xl mx-auto">
        {background.map((item) => (
          <div class="reveal bg-white border border-navy/10 rounded-sm px-5 py-4 text-center text-sm font-accent text-navy">{item}</div>
        ))}
      </div>
    </div>
  </section>

  <Cta title="Meet the founder." text="The best introduction is a conversation. Begin your inquiry or schedule a visit." />
</Base>
