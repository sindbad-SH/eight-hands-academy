---
// ADMISSIONS — reference archetype A (Landing/overview), structure VERIFIED by live Chrome audit of
// aiglon.ch/admissions (2026-06-05). Section order (12 blocks), re-skinned for the Qi-House:
//   1. header band: red-pill eyebrow + H1 + centered intro + wide image + centered primary CTA
//   2. value-prop: IMAGE-left + (highlight heading + copy + inline link) right
//   3. pull-quote band: centered ❝ + serif italic review + attribution + read-more link
//   4. process: TABS (numbered strip + per-tab image/copy-CTA panel)  ← NOT an accordion (live-verified)
//   5. Meet the Team: eyebrow + heading + intro + 4-col PORTRAIT card grid (name link + role, left-aligned)
//   6. "learn more" hub: 3×2 photo cards with CENTERED titles
//   7. full-width video embed
//   8. Planning Your Visit: two NAVY cards (map + virtual tour)
//   9. Visiting card: travel note + address (from salvage)
//   + closing CTA
// All section eyebrows use the red-pill HighlightEyebrow motif (reference signature). No fabrication:
// materials/fees/reviews/staff names are intent-annotated [CONFIRM] placeholders.
import Base from '../layouts/Base.astro';
import SectionSubnav from '../components/SectionSubnav.astro';
import HighlightEyebrow from '../components/HighlightEyebrow.astro';
import GoldArrowLink from '../components/GoldArrowLink.astro';
import ProcessTabs from '../components/ProcessTabs.astro';
import PhotoNavCard from '../components/PhotoNavCard.astro';
import Cta from '../components/Cta.astro';

const subnav: [string, string][] = [
  ['Begin Your Inquiry', '/admissions'],
  ['The Process', '/admissions#process'],
  ["Who You'll Meet", '/admissions#people'],
  ['Visit / Observe a Class', '/admissions#visit'],
];

// Process TABS — the 5-step inquiry journey (reskin-map §3.1). Each panel: image left + subhead/copy/CTA right.
const steps = [
  {
    tab: '1 — Inquire',
    subhead: 'Begin a Conversation',
    body:
      'The first step is a short inquiry. Tell us about the student and what you are seeking from a practice that treats martial arts as the medium for an education in conscious participation. A member of the academy will reach out to begin the conversation.',
    ctaText: 'Begin Your Inquiry',
    ctaHref: '#visit',
    img: '[IMAGE — prospective student/family in conversation with an instructor · 4:3 · 960×720px · candid, warm]',
  },
  {
    tab: '2 — Visit',
    subhead: 'Visit / Observe a Class',
    body:
      'Come to the Qi-House and observe a class. See the environment, the teaching, and the culture of participation firsthand — before any decision is made.',
    ctaText: 'Plan Your Visit',
    ctaHref: '#visit',
    img: '[IMAGE — visitor observing a class from the edge of the training floor · 4:3 · 960×720px]',
  },
  {
    tab: '3 — Apply',
    subhead: 'Apply',
    body:
      'Submit the application materials. [COPY: list the required materials once confirmed with the academy — do not invent forms or a registration fee.]',
    img: '[IMAGE — a considered application moment, not bureaucratic · 4:3 · 960×720px]',
  },
  {
    tab: '4 — Assess',
    subhead: 'Conversation & Assessment',
    body:
      'A developmental conversation and assessment to understand fit, readiness, and the right starting point — not a test to pass, but a way to begin well.',
    img: '[IMAGE — one-on-one developmental conversation · 4:3 · 960×720px]',
  },
  {
    tab: '5 — Decision',
    subhead: 'Decision',
    body:
      'A shared, mutual decision about beginning. Enrollment is considered and deliberate, not transactional.',
    img: '[IMAGE — a student bowing in on their first day on the floor · 4:3 · 960×720px]',
  },
];

const hub: [string, string, string][] = [
  ['Scholarships', '/admissions/scholarships', '[IMAGE — access / support, dignified · 4:3 · 760×570px · CONFIRM program exists]'],
  ['Summer Academy', '/community/summer-academy', '[IMAGE — intensive seasonal practice, outdoors/candid · 4:3 · 760×570px]'],
  ['Events & Gatherings', '/community/events', '[IMAGE — community gathering / demonstration · 4:3 · 760×570px]'],
  ['Meet the Founder', '/about/founder', '[IMAGE — founder portrait / archival origins · 4:3 · 760×570px]'],
  ['The Qi-House Ethos', '/about/ethos', '[IMAGE — ethos / philosophy motif, calm + considered · 4:3 · 760×570px]'],
  ['Community Impact', '/community/impact', '[IMAGE — service / contribution beyond the studio · 4:3 · 760×570px]'],
];
---
<Base home title="Admissions · Begin Your Inquiry — The Qi-House" description="Admission to the Qi-House begins with a conversation, not a checkout.">
  <SectionSubnav items={subnav} active="/admissions" label="Admissions section" />

  <!-- 1. Header band: eyebrow pill + H1 + centered intro + wide image + centered primary CTA -->
  <section class="bg-stone">
    <div class="container-content py-section-sm lg:py-section">
      <div class="text-center max-w-3xl mx-auto reveal">
        <div class="flex justify-center mb-5"><HighlightEyebrow mark="Welcome to the Qi-House" /></div>
        <h1 class="text-4xl lg:text-5xl text-navy mb-6">Qi-House Admissions</h1>
        <p class="text-slate/90 text-lg leading-relaxed">
          Founded in 1992, the academy was built on the balanced development of mind, body, and discernment —
          a philosophy that still guides everything here. Admission is an invitation, and we welcome inquiries
          from students ready to participate consciously in their own growth.
        </p>
      </div>
      <div class="ph aspect-[16/6] mt-12 reveal">[IMAGE — wide establishing shot of the Qi-House / training space · 16:6 · 1760×660px · calm, grounded, architectural]</div>
      <div class="text-center mt-10 reveal">
        <a href="#visit" class="btn-accent">Begin Your Inquiry</a>
      </div>
    </div>
  </section>

  <!-- 2. Value-prop: IMAGE left + (highlight heading + copy + inline link) right -->
  <section class="bg-stone-200">
    <div class="container-content py-section-sm lg:py-section grid lg:grid-cols-2 gap-14 lg:gap-20 items-center">
      <div class="ph aspect-[4/3] reveal !text-[10px]">[IMAGE — an open day / family meeting an instructor on the floor · 4:3 · 1040×780px · candid]</div>
      <div class="reveal">
        <p class="font-accent uppercase tracking-[0.14em] text-xl lg:text-2xl text-navy mb-7 inline-flex flex-wrap items-center gap-x-2.5 gap-y-1">
          <span>An</span><span class="bg-red text-stone px-2 py-0.5">Invitation</span><span>to Join Us</span>
        </p>
        <p class="text-slate/90 leading-relaxed mb-5">
          To ensure every new student can genuinely thrive within the community, the Qi-House keeps a
          considered, unhurried admissions process.
        </p>
        <p class="text-slate/90 leading-relaxed mb-5">
          We look at each applicant in terms of fit — whether the practice can truly serve their development,
          and whether they are ready to meet it. The medium is martial arts; the work is conscious participation.
        </p>
        <p class="text-slate/90 leading-relaxed">
          The best way to understand the Qi-House is to
          <a href="#visit" class="text-navy font-medium underline decoration-red/60 underline-offset-2 hover:text-red transition-colors">submit an inquiry</a>,
          so we can begin sharing the practice, the community, and the culture with you directly.
        </p>
      </div>
    </div>
  </section>

  <!-- 3. Pull-quote band: centered ❝ + serif italic review + attribution + read-more -->
  <section class="bg-stone">
    <div class="container-content py-section-sm lg:py-section">
      <div class="max-w-3xl mx-auto text-center reveal">
        <div class="border-t border-navy/10 relative mb-8">
          <span class="absolute left-1/2 -translate-x-1/2 -top-5 bg-stone px-3 font-display text-5xl leading-none text-red">&ldquo;</span>
        </div>
        <blockquote class="font-display text-2xl lg:text-3xl text-navy italic leading-snug mb-6">
          [PULL-QUOTE — a real external review or endorsement of the academy. 1–2 sentences, serif italic. Never fabricated.]
        </blockquote>
        <div class="font-accent text-navy font-semibold mb-1">[Source — publication or person · CONFIRM]</div>
        <div class="eyebrow !text-slate-400 mb-6">[Year · context]</div>
        <GoldArrowLink href="#" text="Read the Full Review" class="justify-center" />
      </div>
    </div>
  </section>

  <!-- 4. Process TABS -->
  <section id="process" class="bg-stone-200 scroll-mt-24">
    <div class="container-content py-section-sm lg:py-section">
      <ProcessTabs eyebrow="Step by Step" heading="The Admissions Process" steps={steps} />
    </div>
  </section>

  <!-- 5. Meet the Team: 4-col PORTRAIT grid, name link + role left-aligned -->
  <section id="people" class="bg-stone scroll-mt-24">
    <div class="container-content py-section-sm lg:py-section">
      <div class="text-center max-w-2xl mx-auto mb-12 reveal">
        <div class="flex justify-center mb-4"><HighlightEyebrow mark="Here to Help" /></div>
        <h2 class="text-3xl lg:text-4xl mb-5">Meet the Team</h2>
        <p class="text-slate/90">
          The team is here to support each step — a question, a visit, or beginning the journey. We look forward
          to welcoming your family to the Qi-House community.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-10">
        {Array.from({ length: 4 }).map((_, i) => (
          <div class="reveal">
            <div class="ph aspect-[3/4] mb-3 !text-[10px]">[PORTRAIT {i + 1} — 720×960px (3:4) · admissions lead / instructor, candid not posed]</div>
            <a href="/about/leadership" class="font-display text-lg text-navy underline decoration-red/50 underline-offset-2 hover:text-red transition-colors">[Name — confirm]</a>
            <div class="eyebrow !text-slate-400 mt-1">[Role — confirm]</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. "Learn more" hub: 3×2 photo cards, CENTERED titles -->
  <section class="bg-stone-200">
    <div class="container-content py-section-sm lg:py-section">
      <div class="text-center max-w-2xl mx-auto mb-12 reveal">
        <div class="flex justify-center mb-4"><HighlightEyebrow mark="The Qi-House Story" /></div>
        <h2 class="text-3xl lg:text-4xl">Learn More</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3">
        {hub.map(([label, href, alt]) => (
          <div class="reveal"><PhotoNavCard label={label} href={href} alt={alt} center /></div>
        ))}
      </div>
    </div>
  </section>

  <!-- 7. Full-width video embed -->
  <section class="bg-navy">
    <div class="container-content py-section-sm lg:py-section">
      <div class="ph aspect-video relative group cursor-pointer">
        [VIDEO — admissions film / "A Day at the Qi-House" · 16:9 · real lazy embed + poster, not a flat image]
        <span class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-16 h-16 rounded-full bg-red flex items-center justify-center transition-transform duration-200 group-hover:scale-110">
          <svg width="18" height="22" viewBox="0 0 10 12" class="text-stone ml-1" fill="currentColor"><polygon points="0,0 10,6 0,12" /></svg>
        </span>
      </div>
    </div>
  </section>

  <!-- 8. Planning Your Visit: two NAVY cards (#visit anchor) -->
  <section id="visit" class="bg-stone scroll-mt-24">
    <div class="container-content py-section-sm lg:py-section">
      <div class="text-center max-w-2xl mx-auto mb-12 reveal">
        <div class="flex justify-center mb-4"><HighlightEyebrow mark="Planning Your Visit" /></div>
        <h2 class="text-3xl lg:text-4xl">Visit the Qi-House</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {[
          ['Find the Qi-House', '[IMAGE — the Qi-House entrance / exterior · 16:9 · 880×495px]', 'View Directions & Map', '#visit'],
          ['Take a Virtual Tour', '[IMAGE — interior of the training space, wide · 16:9 · 880×495px]', 'Tour the Space', '#'],
        ].map(([title, img, btn, href]) => (
          <div class="reveal bg-navy p-5 lg:p-6">
            <h3 class="font-accent uppercase tracking-[0.1em] text-stone text-lg lg:text-xl mb-4">{title}</h3>
            <div class="ph aspect-video !rounded-none mb-4">{img}</div>
            <a href={href} class="btn-ghost w-full !border-stone/40 !text-stone hover:!bg-stone hover:!text-navy">{btn}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 9. Visiting card: travel note + address (from salvage) -->
  <section class="bg-stone-200">
    <div class="container-content py-section-sm">
      <div class="max-w-3xl mx-auto text-center reveal bg-stone border border-navy/10 px-6 py-10 lg:px-12">
        <div class="flex justify-center mb-6"><HighlightEyebrow mark="Visiting the Qi-House" /></div>
        <p class="text-slate/90 leading-relaxed mb-7">
          [TRAVEL — how to reach the Qi-House: nearest transit, parking, and any visitor note. Confirm details
          with the academy; do not invent directions.]
        </p>
        <address class="not-italic text-slate space-y-1">
          <p>[ADDRESS — confirm from salvage]</p>
          <p>[CITY, REGION — confirm]</p>
          <p>[PHONE — confirm]</p>
        </address>
      </div>
    </div>
  </section>

  <Cta title="Begin your inquiry." text="Tell us about the student. We will take it from there — at the pace a real decision deserves." />
</Base>
