---
// ADMISSIONS — reference archetype A (Landing/overview), structure VERIFIED by live Chrome audit of
// aiglon.ch/admissions (2026-06-05). Section order (12 blocks), re-skinned for the Qi-House:
//   1. header band: red-pill eyebrow + H1 + centered intro + wide image + centered primary CTA
//   2. value-prop: IMAGE-left + (highlight heading + copy + inline link) right
//   3. pull-quote band: centered ❝ + serif italic review + attribution + read-more link
//   4. process: TABS (numbered strip + per-tab image/copy-CTA panel)  ← NOT an accordion (live-verified)
//   5. Meet the Team: eyebrow + heading + intro + 4-col PORTRAIT card grid (name link + role, left-aligned)
//   6. "learn more" hub: 3×2 photo cards with CENTERED titles
//   7. full-width video embed
//   8. Planning Your Visit: two NAVY cards (map + virtual tour)
//   9. Visiting card: travel note + address (from salvage)
//   + closing CTA
// All section eyebrows use the red-pill HighlightEyebrow motif (reference signature). No fabrication:
// materials/fees/reviews/staff names are intent-annotated [CONFIRM] placeholders.
import Base from '../layouts/Base.astro';
import SectionSubnav from '../components/SectionSubnav.astro';
import HighlightEyebrow from '../components/HighlightEyebrow.astro';
import GoldArrowLink from '../components/GoldArrowLink.astro';
import ProcessTabs from '../components/ProcessTabs.astro';
import PhotoNavCard from '../components/PhotoNavCard.astro';
import Cta from '../components/Cta.astro';
import { BOOKING_URL, withBase, CONTACT } from '../data/site';

const subnav: [string, string][] = [
  ['Schedule an Assessment', '/admissions'],
  ['The Process', '/admissions#process'],
  ["Who You'll Meet", '/admissions#people'],
  ['Visit / Observe a Class', '/admissions#visit'],
];

// Process TABS — the ADS 8-step admissions flow (Inquiry → 90-Day Review). Each panel: image left +
// subhead/copy/CTA right. Outcomes-led; the assessment is a recommendation, not a sale. CTAs book an
// assessment at the live scheduling link.
const steps = [
  {
    tab: '1 — Inquiry',
    subhead: 'Tell Us What You Are Working Toward',
    body:
      'Start by telling us about the student and the outcomes you are after — confidence, discipline, focus, leadership, or a clearer sense of self-governance. Membership establishes your place within the academy, and the educational pathway we recommend determines how you develop within it. Your inquiry simply opens that conversation.',
    ctaText: 'Schedule an Assessment',
    ctaHref: BOOKING_URL,
    img: '/img/instruction-2.jpg',
  },
  {
    tab: '2 — Assessment Booking',
    subhead: 'Reserve a Time That Works for You',
    body:
      'Book your assessment directly. This is a developmental conversation, not a sales presentation — a chance to understand the goals, challenges, and readiness of the student before any pathway is recommended.',
    ctaText: 'Schedule an Assessment',
    ctaHref: BOOKING_URL,
    img: '/img/reflection-1.jpg',
  },
  {
    tab: '3 — Pre-Assessment Questionnaire',
    subhead: 'Clarify Goals Before You Arrive',
    body:
      'Ahead of the session, a short questionnaire helps surface what the student wants to develop and where they are starting from. It lets the conversation begin from understanding rather than guesswork, so the recommendation fits the person.',
    img: '/img/instruction-1.jpg',
  },
  {
    tab: '4 — Assessment Session',
    subhead: 'A Developmental Conversation',
    body:
      'The assessment is a guided conversation about goals, challenges, and readiness — not a test to pass and not a sales pitch. It is where we learn how the practice can serve the student\'s growth in focus, resilience, and accountability.',
    img: '/img/instruction-3.jpg',
  },
  {
    tab: '5 — Program Recommendation',
    subhead: 'A Recommendation, Not a Sale',
    body:
      'Based on the conversation, we recommend the educational pathway that best fits the student — Academy Membership, Academy Scholar, or Academy Fellow (by invitation). You are guided toward the right starting point rather than asked to choose blindly.',
    img: '/img/mentoring-2.jpg',
  },
  {
    tab: '6 — Enrollment',
    subhead: 'Begin With Intention',
    body:
      'Enrollment is a considered, mutual decision to begin. It marks a commitment to the work of self-governance — deliberate and intentional, never transactional.',
    img: '/img/instruction-2.jpg',
  },
  {
    tab: '7 — Orientation',
    subhead: 'Start on Solid Ground',
    body:
      'Orientation introduces the student to the culture, expectations, and rhythm of the academy. Individualized Instruction is the education, group instruction the application laboratory — and orientation sets the foundation for both.',
    img: '/img/interior-wide.jpg',
  },
  {
    tab: '8 — 90-Day Review',
    subhead: 'Measure Real Progress',
    body:
      'At ninety days, we review progress against the outcomes set at the assessment — growth in discipline, awareness, communication, and confidence — and adjust the path forward. Development is tracked, not assumed.',
    img: '/img/instruction-1.jpg',
  },
];

const hub: [string, string, string, string][] = [
  ['Scholarship & Stewardship', '/admissions/scholarships', '[IMAGE — access / support, dignified · 4:3 · 760×570px]', '/img/service-1.jpg'],
  ['Summer Academy', '/community/summer-academy', '[IMAGE — intensive seasonal practice, outdoors/candid · 4:3 · 760×570px]', '/img/group-2.jpg'],
  ['Events & Gatherings', '/community/events', '[IMAGE — community gathering / demonstration · 4:3 · 760×570px]', '/img/group-1.jpg'],
  ['Meet the Founder', '/about/founder', '[IMAGE — founder instructing / origins · 4:3 · 760×570px]', '/img/instruction-1.jpg'],
  ['The Qi-House Ethos', '/about/ethos', '[IMAGE — ethos / philosophy motif, calm + considered · 4:3 · 760×570px]', '/img/environment-1.jpg'],
  ['Community Impact', '/community/impact', '[IMAGE — service / contribution beyond the studio · 4:3 · 760×570px]', '/img/mentoring-1.jpg'],
];
---
<Base home title="Admissions · Schedule an Assessment — The Qi-House" description="Admission to Eight Hands begins with an assessment — a developmental conversation about goals and readiness, not a sales presentation.">
  <SectionSubnav items={subnav} active="/admissions" label="Admissions section" />

  <!-- 1. Header band: eyebrow pill + H1 + centered intro + wide image + centered primary CTA -->
  <section class="bg-stone">
    <div class="container-content py-section-sm lg:py-section">
      <div class="text-center max-w-3xl mx-auto reveal">
        <div class="flex justify-center mb-5"><HighlightEyebrow mark="Admissions at Eight Hands" /></div>
        <h1 class="text-4xl lg:text-5xl text-navy mb-6">Begin With an Assessment</h1>
        <p class="text-slate/90 text-lg leading-relaxed">
          Eight Hands is an educational institution whose medium is martial arts, and admission here is a
          recommendation, not a sale. We help students develop the confidence, discipline, focus, and
          self-governance to lead their own lives well — and it starts with a conversation about where you
          are and where you want to go.
        </p>
      </div>
      <img src={withBase('/img/interior-wide.jpg')} alt="The Qi-House training space" loading="lazy" class="aspect-[16/6] mt-12 reveal w-full object-cover" />
      <div class="text-center mt-10 reveal">
        <a href={BOOKING_URL} target="_blank" rel="noopener" class="btn-accent">Schedule an Assessment</a>
      </div>
    </div>
  </section>

  <!-- 2. Value-prop: MIRRORED — IMAGE right + (highlight heading + copy + inline link) left on lg -->
  <section class="bg-stone-200">
    <div class="container-content py-section-sm lg:py-section grid lg:grid-cols-2 gap-14 lg:gap-20 items-center">
      <img src={withBase('/img/community-1.jpg')} alt="An open day at the Qi-House" loading="lazy" class="aspect-[4/3] reveal lg:order-2 w-full object-cover" />
      <div class="reveal lg:order-1">
        <p class="font-accent uppercase tracking-[0.14em] text-xl lg:text-2xl text-navy mb-7 inline-flex flex-wrap items-center gap-x-2.5 gap-y-1">
          <span>A</span><span class="bg-red text-stone px-2 py-0.5">Recommended</span><span>Path</span>
        </p>
        <p class="text-slate/90 leading-relaxed mb-5">
          Membership establishes a student’s place within the academy; educational pathways determine how they
          develop within it. The admissions process is considered and unhurried because the goal is a genuine fit, not a quick close.
        </p>
        <p class="text-slate/90 leading-relaxed mb-5">
          We meet each student where they are and look at what they want to develop — confidence, focus,
          resilience, leadership, accountability. The medium is martial arts; the work is learning to govern
          yourself before you set out to influence the world.
        </p>
        <p class="text-slate/90 leading-relaxed">
          The clearest way to understand whether Eight Hands is right for you is to
          <a href={BOOKING_URL} target="_blank" rel="noopener" class="text-navy font-medium underline decoration-red/60 underline-offset-2 hover:text-red transition-colors">schedule an assessment</a> —
          a developmental conversation about goals and readiness, not a sales presentation.
        </p>
      </div>
    </div>
  </section>

  <!-- 3. Pull-quote band: centered ❝ + serif italic review + attribution + read-more -->
  <section class="bg-stone">
    <div class="container-content py-section-sm lg:py-section">
      <div class="max-w-3xl mx-auto text-center reveal">
        <div class="border-t border-navy/10 relative mb-8">
          <span class="absolute left-1/2 -translate-x-1/2 -top-5 bg-stone px-3 font-display text-5xl leading-none text-red">&ldquo;</span>
        </div>
        <blockquote class="font-display text-2xl lg:text-3xl text-navy italic leading-snug mb-6">
          &ldquo;The classes have helped me understand people more accurately and become far more intentional in how I approach communication, decision-making, and problem-solving. It has made communications clearer and negotiations more effective.&rdquo;
        </blockquote>
        <div class="font-accent text-navy font-semibold mb-1">Kelsey Cain · Student Review</div>
        <div class="eyebrow !text-slate-400 mb-6">2026 · Neurohacking Program</div>
        <details class="max-w-2xl mx-auto text-left">
          <summary class="cursor-pointer list-none text-center font-accent text-xs uppercase tracking-[0.18em] font-semibold text-gold-600 hover:text-gold">Read the Full Review →</summary>
          <p class="mt-5 text-slate/90 leading-relaxed">8 Hands Neurohacking classes have been genuinely transformative for me. The material goes far beyond theory and gives practical, strategic tools that I&rsquo;ve been able to apply directly to real business decisions. One of the biggest benefits has been learning how to read people more accurately. The classes help me understand mental processes by identifying behavioral patterns and decision-making cues in others and I&rsquo;ve become much more intentional in how I approach, analyze, and develop solutions. It has made communications clearer and negotiations more effective. I now feel more confident breaking down why people think the way they do and adjusting my approach to interactions in a way that&rsquo;s ethical, grounded, and strategic. 8 Hands provides deep insight and practical frameworks that can be applied in multiple aspects of our day to day interactions. If you&rsquo;re serious about improving your mindset, decision-making, and understanding of human behavior, especially in a business context, these classes are absolutely worth it.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- 4. Process TABS -->
  <section id="process" class="bg-stone-200 scroll-mt-24">
    <div class="container-content py-section-sm lg:py-section">
      <ProcessTabs eyebrow="What Happens Next" heading="The Admissions Process" steps={steps} />
    </div>
  </section>

  <!-- 5. Meet the Team: 4-col PORTRAIT grid, name link + role left-aligned -->
  <section id="people" class="bg-stone scroll-mt-24">
    <div class="container-content py-section-sm lg:py-section">
      <div class="text-center max-w-2xl mx-auto mb-12 reveal">
        <div class="flex justify-center mb-4"><HighlightEyebrow mark="Here to Help" /></div>
        <h2 class="text-3xl lg:text-4xl mb-5">Meet the Team</h2>
        <p class="text-slate/90">
          You will work with real instructors from your first conversation onward. They are here to answer
          questions, host your visit, and guide your assessment — so you can make a clear, confident decision
          about beginning.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-10 items-start">
        {[
          ['/img/kasemir-portrait.jpg', 'Dr. Kasemir, Kyoshi', 'Director · Head Instructor'],
          ['/img/sang-portrait.jpg', 'Sang Nguyen', 'Director of Operations'],
          ['/img/cole-portrait.jpg', 'Cole Wilson', 'Assistant Instructor'],
          ['/img/juan-portrait.jpg', 'Juan Gurule', 'Assistant Instructor'],
        ].map(([portrait, name, role]) => (
          <div class="reveal">
            <img src={withBase(portrait)} alt={name} loading="lazy" class="aspect-[3/4] mb-3 w-full object-cover" />
            <a href={withBase('/about/leadership')} class="font-display text-lg text-navy underline decoration-red/50 underline-offset-2 hover:text-red transition-colors">{name}</a>
            <div class="eyebrow !text-slate-400 mt-1">{role}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. "Learn more" hub: 3×2 photo cards, CENTERED titles -->
  <section class="bg-stone-200">
    <div class="container-content py-section-sm lg:py-section">
      <div class="text-center max-w-2xl mx-auto mb-12 reveal">
        <div class="flex justify-center mb-4"><HighlightEyebrow mark="The Qi-House Story" /></div>
        <h2 class="text-3xl lg:text-4xl">Learn More</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3">
        {hub.map(([label, href, alt, img]) => (
          <div class="reveal"><PhotoNavCard label={label} href={href} alt={alt} img={img} center /></div>
        ))}
      </div>
    </div>
  </section>

  <!-- 7. Full-width video embed -->
  <section class="bg-navy">
    <div class="container-content py-section-sm lg:py-section">
      <div class="ph aspect-video relative group cursor-pointer">
        [VIDEO — admissions film / "A Day at the Qi-House" · 16:9 · real lazy embed + poster, not a flat image]
        <span class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-16 h-16 rounded-full bg-red flex items-center justify-center transition-transform duration-200 group-hover:scale-110">
          <svg width="18" height="22" viewBox="0 0 10 12" class="text-stone ml-1" fill="currentColor"><polygon points="0,0 10,6 0,12" /></svg>
        </span>
      </div>
    </div>
  </section>

  <!-- 8. Planning Your Visit: two NAVY cards (#visit anchor) -->
  <section id="visit" class="bg-stone scroll-mt-24">
    <div class="container-content py-section-sm lg:py-section">
      <div class="text-center max-w-2xl mx-auto mb-12 reveal">
        <div class="flex justify-center mb-4"><HighlightEyebrow mark="Planning Your Visit" /></div>
        <h2 class="text-3xl lg:text-4xl">Visit the Qi-House</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        <!-- Find the Qi-House: live Google Map -->
        <div class="reveal bg-navy p-5 lg:p-6">
          <h3 class="font-accent uppercase tracking-[0.1em] text-stone text-lg lg:text-xl mb-4">Find the Qi-House</h3>
          <div class="aspect-video overflow-hidden mb-4 bg-stone/10">
            <iframe src={CONTACT.mapEmbed} title="Eight Hands Martial Arts — Longmont, CO" loading="lazy" referrerpolicy="no-referrer-when-downgrade" class="w-full h-full" style="border:0;"></iframe>
          </div>
          <a href={CONTACT.mapUrl} target="_blank" rel="noopener" class="btn-ghost w-full !border-stone/40 !text-stone hover:!bg-stone hover:!text-navy">View on Google Maps</a>
        </div>
        <!-- Take a Virtual Tour -->
        <div class="reveal bg-navy p-5 lg:p-6">
          <h3 class="font-accent uppercase tracking-[0.1em] text-stone text-lg lg:text-xl mb-4">Take a Virtual Tour</h3>
          <div class="aspect-video overflow-hidden mb-4"><img src={withBase('/img/environment-2.jpg')} alt="Inside the Qi-House" loading="lazy" class="w-full h-full object-cover" /></div>
          <a href="#" class="btn-ghost w-full !border-stone/40 !text-stone hover:!bg-stone hover:!text-navy">Tour the Space</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 9. Visiting card: travel note + address (from salvage) -->
  <section class="bg-stone-200">
    <div class="container-content py-section-sm">
      <div class="max-w-3xl mx-auto text-center reveal bg-stone border border-navy/10 px-6 py-10 lg:px-12">
        <div class="flex justify-center mb-6"><HighlightEyebrow mark="Visiting the Qi-House" /></div>
        <p class="text-slate/90 leading-relaxed mb-7">
          The Qi-House is located in Longmont, Colorado. Use the map to find us and get directions, or reach
          out any time and we'll help you plan your visit.
        </p>
        <address class="not-italic text-slate space-y-1">
          <p>{CONTACT.address}</p>
          <p><a href={CONTACT.phoneHref} class="text-red hover:text-navy underline decoration-red/40 underline-offset-2">{CONTACT.phone}</a></p>
          <p><a href={`mailto:${CONTACT.email}`} class="text-red hover:text-navy underline decoration-red/40 underline-offset-2">{CONTACT.email}</a></p>
          <p><a href={CONTACT.mapUrl} target="_blank" rel="noopener" class="text-red hover:text-navy underline decoration-red/40 underline-offset-2">View on Google Maps</a></p>
        </address>
      </div>
    </div>
  </section>

  <Cta title="Begin your inquiry." text="Tell us about the student. We will take it from there — at the pace a real decision deserves." />
</Base>
