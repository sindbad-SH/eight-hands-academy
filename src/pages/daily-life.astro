---
// DAILY LIFE — reskin of the reference "Student Life" page, structure VERIFIED by live Chrome audit of
// aiglon.ch/student-life (2026-06-05). Reference shape: LEFT-aligned H1 (no eyebrow), one image-left +
// highlight-heading + copy + ClaimRotator intro, then a centered-title photo hub of sub-topics, no closing
// CTA. Adaptation: the reference routes "Reflection / Wellbeing" to separate pages via the hub; we HAVE real
// content for those, so they're kept as inline anchored bands (so the nav anchors resolve) AND surfaced in
// the hub. The Twelve Domains are REFERENCED, never explained (directive) — a hub card links out.
import Base from '../layouts/Base.astro';
import { withBase } from '../data/site';
import SectionSubnav from '../components/SectionSubnav.astro';
import GoldArrowLink from '../components/GoldArrowLink.astro';
import ClaimRotator from '../components/ClaimRotator.astro';
import PhotoNavCard from '../components/PhotoNavCard.astro';

const subnav: [string, string][] = [
  ['The Qi-House Environment', '/daily-life'],
  ['Reflection & Presence', '/daily-life#reflection'],
  ['Wellbeing & Safety', '/daily-life#wellbeing'],
  ['The Twelve Domains', '/the-twelve-houses'],
];

const claims: [string, string][] = [
  ['Focus & Attention', 'The environment is arranged for order and attention, so students build the focus that carries into the rest of life.'],
  ['Discipline & Awareness', 'Stillness, breath, and review are part of the training — the habits that grow self-awareness and self-governance.'],
  ['Resilience within Safety', 'Clear standards for physical and psychological wellbeing create the conditions for real growth and accountability.'],
  ['A Community of Practice', 'Daily life is lived alongside others, where confidence and leadership are practiced, not just taught.'],
];

const hub: [string, string, string, string][] = [
  ['The Twelve Domains', '/the-twelve-houses', '[IMAGE — an evocative, non-literal motif for the Domains · 4:3 · 760×570px]', '/img/reflection-1.jpg'],
  ['Reflection & Presence', '/daily-life#reflection', '[IMAGE — a still, reflective moment before/after practice · 4:3 · 760×570px]', '/img/environment-1.jpg'],
  ['Wellbeing & Safety', '/daily-life#wellbeing', '[IMAGE — attentive instruction, care on the floor · 4:3 · 760×570px]', '/img/instruction-1.jpg'],
  ['The Practice Environment', '/daily-life#environment', '[IMAGE — the training space, ordered and calm · 4:3 · 760×570px]', '/img/interior-wide.jpg'],
  ['Stillness & Meditation', '/daily-life#reflection', '[IMAGE — seated stillness / breath work · 4:3 · 760×570px]', '/img/environment-3.jpg'],
  ['A Day at the Qi-House', '/admissions#visit', '[IMAGE — the rhythm of a training day, candid · 4:3 · 760×570px]', '/img/group-1.jpg'],
];
---
<Base home title="Daily Life — The Qi-House" description="An environment designed to build focus, discipline, and self-awareness in the ordinary work of daily practice.">
  <SectionSubnav items={subnav} active="/daily-life" label="Daily Life section" />

  <!-- Left-aligned page title (reference: Student Life), then intro block -->
  <section id="environment" class="bg-stone scroll-mt-24">
    <div class="container-content py-section-sm lg:py-section">
      <h1 class="text-4xl lg:text-5xl text-navy mb-12 lg:mb-16">Daily Life</h1>

      <div class="grid lg:grid-cols-2 gap-14 lg:gap-20 items-start">
        <img src={withBase('/img/environment-2.jpg')} alt="Students at ease in the Qi-House environment" loading="lazy" class="aspect-[4/3] reveal lg:order-2 w-full object-cover" />
        <div class="reveal lg:order-1">
          <p class="font-accent uppercase tracking-[0.14em] text-xl lg:text-2xl text-navy mb-7 inline-flex flex-wrap items-center gap-x-2.5 gap-y-1">
            <span>An Education in</span><span class="bg-red text-stone px-2 py-0.5">Presence</span>
          </p>
          <p class="text-slate/90 leading-relaxed mb-5">
            Daily life at the Qi-House is the place where confidence, discipline, and focus are built in the
            ordinary work of showing up. The environment is arranged to support attention and self-governance:
            how a student prepares, trains, and conducts themselves matters as much as any single technique.
          </p>
          <p class="text-slate/90 leading-relaxed mb-8">
            The practice is made ordinary — arriving, preparing, training, reflecting, and carrying what is
            learned back out into the world. Over time, the awareness developed here becomes the way a student
            governs their own attention, effort, and conduct everywhere else.
          </p>
          <GoldArrowLink href="/the-twelve-houses" text="The Twelve Domains" class="mb-10" />
          <ClaimRotator items={claims} dark={false} label="What daily life is arranged to do" />
        </div>
      </div>
    </div>
  </section>

  <!-- Reflection & Presence (anchored sub-topic; copy-left / image-right) -->
  <section id="reflection" class="bg-stone-200 scroll-mt-24">
    <div class="container-content py-section-sm lg:py-section grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="reveal lg:order-2">
        <p class="eyebrow mb-4">Reflection &amp; Presence</p>
        <h2 class="text-3xl mb-5">Awareness is trained alongside movement.</h2>
        <p class="text-slate/90 leading-relaxed">
          Reflection is not an interlude; it is how focus and self-awareness are built. Time for stillness,
          breath, and review is part of the rhythm of training — the place where movement becomes
          understanding, and where a student learns to observe and govern their own attention.
        </p>
      </div>
      <img src={withBase('/img/reflection-2.jpg')} alt="A quiet, reflective moment before practice" loading="lazy" class="reveal aspect-[4/3] lg:order-1 w-full object-cover" />
    </div>
  </section>

  <!-- Wellbeing & Safety (anchored sub-topic; image-left / copy-right) -->
  <section id="wellbeing" class="bg-stone scroll-mt-24">
    <div class="container-content py-section-sm lg:py-section grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <img src={withBase('/img/instruction-2.jpg')} alt="Attentive instruction and care on the training floor" loading="lazy" class="reveal aspect-[4/3] lg:order-2 w-full object-cover" />
      <div class="reveal lg:order-1">
        <p class="eyebrow mb-4">Wellbeing &amp; Safety</p>
        <h2 class="text-3xl mb-5">Real growth requires safety.</h2>
        <p class="text-slate/90 leading-relaxed">
          The academy holds clear standards for the physical and psychological wellbeing of every student.
          Challenge is real, but it is held within care — the conditions that let a person build resilience by
          taking a risk worth taking, and accept accountability without fear.
        </p>
      </div>
    </div>
  </section>

  <!-- Photo hub: facets of daily life (centered titles), incl. The Twelve Domains (referenced, not explained) -->
  <section class="bg-stone-200">
    <div class="container-content py-section-sm lg:py-section">
      <div class="text-center max-w-2xl mx-auto mb-12 reveal">
        <h2 class="text-3xl lg:text-4xl">Life at the Qi-House</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3">
        {hub.map(([label, href, alt, img]) => (
          <div class="reveal"><PhotoNavCard label={label} href={href} alt={alt} img={img} center /></div>
        ))}
      </div>
    </div>
  </section>
</Base>
