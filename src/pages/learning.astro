---
// LEARNING — reference archetype A (Landing/overview), structure VERIFIED by live Chrome audit of
// aiglon.ch/learning (2026-06-05). Section order (6 blocks), re-skinned for the Qi-House:
//   1. header band: red-pill eyebrow + H1 + centered intro + wide image
//   2. cohorts: eyebrow + heading + two NAVY group cards + 4 photo cohort cards (red-pill stage label)
//   3. "More than technique": layered photo pair + ▶ pill (left) + highlight heading + copy + ClaimRotator (right)
//   4. The Framework: heading + two-column (segmented wheel diagram + 7-row disclosure ACCORDION)
//   5. "Go Deeper" hub: red-pill eyebrow + heading + photo-card grid (centered titles)
//   + closing CTA
import Base from '../layouts/Base.astro';
import SectionSubnav from '../components/SectionSubnav.astro';
import HighlightEyebrow from '../components/HighlightEyebrow.astro';
import GoldArrowLink from '../components/GoldArrowLink.astro';
import ParallaxPhoto from '../components/ParallaxPhoto.astro';
import ClaimRotator from '../components/ClaimRotator.astro';
import PhotoNavCard from '../components/PhotoNavCard.astro';
import Cta from '../components/Cta.astro';

const subnav: [string, string][] = [
  ['Learning', '/learning'],
  ['The Cohorts', '/learning#cohorts'],
  ['The Framework', '/learning#framework'],
  ['How We Learn', '/learning#programs'],
];

// Two group cards (reference: Junior/Senior School) → two arcs of the practice.
const groups = [
  ['Beginning', 'The Foundation', 'Wonder & Discovery — learning to perceive, and to participate.', '#wonder'],
  ['Continuing', 'The Application', 'Exploration & Integration — discernment, responsibility, and stewardship.', '#exploration'],
];

// Four cohorts (reference: Wonder/Discovery/Exploration/Inspiration → Integration). Stage label, not age years.
const cohorts: [string, string, string, string][] = [
  ['wonder', 'Wonder', 'Beginning', 'Foundation through curiosity — learning to perceive more clearly.'],
  ['discovery', 'Discovery', 'Developing', 'Foundation through experience — learning to choose deliberately.'],
  ['exploration', 'Exploration', 'Refining', 'Foundation through responsibility — learning to act with discernment.'],
  ['integration', 'Integration', 'Integrating', 'Foundation through application — participating consciously across systems.'],
];

// Rotating claims for the "More than technique" intro card (reference: panel-05 rotating claim card).
const claims: [string, string][] = [
  ['A Multidisciplinary Practice', 'The diploma of this practice is not a belt — it is the capacity to participate consciously.'],
  ['Mind, Body & Discernment', 'Three faculties developed together; none advanced at the expense of another.'],
  ['Beyond the Training Floor', 'The work is meant to be carried into every system the student moves within.'],
  ['Practiced Since 1992', 'Decades of disciplined study, refined into a coherent methodology.'],
];

// The 7-principle Constitutional Framework (reskin-map §3.2) — a disclosure accordion + a segmented wheel.
const framework: [string, string][] = [
  ['Choice', 'The ability to govern participation — to act rather than merely react.'],
  ['Presence', 'The capacity to contain awareness in the moment, without drifting from it.'],
  ['Awareness', 'Recognition of existence and condition — of oneself, others, and the system.'],
  ['Discernment', 'Determining what to do with awareness; judgment under real conditions.'],
  ['Responsibility', 'Ownership of choice and of its consequence, claimed rather than assigned.'],
  ['Capability', 'The developed ability to perform effectively when it matters.'],
  ['Stewardship', 'To contribute responsibly to systems larger than oneself.'],
];

// Build the segmented framework wheel (7 equal arcs, cycling navy/red/gold) + label positions.
const wheelColors = ['#0B2341', '#8C1D18', '#C9A44C'];
const segDeg = 360 / framework.length;
const wheelStops = framework
  .map((_, i) => `${wheelColors[i % 3]} ${(i * segDeg).toFixed(2)}deg ${((i + 1) * segDeg).toFixed(2)}deg`)
  .join(', ');
const wheelLabels = framework.map(([name], i) => {
  const a = ((i + 0.5) * segDeg - 90) * (Math.PI / 180);
  const r = 35; // % from center
  return { name, x: (50 + r * Math.cos(a)).toFixed(1), y: (50 + r * Math.sin(a)).toFixed(1) };
});

// "Go Deeper / How We Learn" hub — the program modules (reskin-map §3.2).
const programs: [string, string, string][] = [
  ['The Core — Private Instruction', '/learning#programs', '[IMAGE — one-on-one instruction, mentor + student · 4:3 · 760×570px]'],
  ['The Application — Group Training', '/learning#programs', '[IMAGE — group practice on the floor, candid · 4:3 · 760×570px]'],
  ['Summer Academy', '/community/summer-academy', '[IMAGE — intensive seasonal practice, outdoors · 4:3 · 760×570px]'],
  ['Instructor Development', '/community/instructor-development', '[IMAGE — senior student teaching / leading · 4:3 · 760×570px]'],
];
---
<Base home title="Learning at the Qi-House" description="An education in participation — martial arts as the medium.">
  <SectionSubnav items={subnav} active="/learning" label="Learning section" />

  <!-- 1. Header band -->
  <section class="bg-stone">
    <div class="container-content py-section-sm lg:py-section">
      <div class="text-center max-w-3xl mx-auto reveal">
        <div class="flex justify-center mb-5"><HighlightEyebrow mark="Holistic Practice" /></div>
        <h1 class="text-4xl lg:text-5xl text-navy mb-6">Learning at the Qi-House</h1>
        <p class="text-slate/90 text-lg leading-relaxed">
          The objective is not a catalogue of techniques but the mastery of participation. The novice sees
          pieces; the advanced student sees relationships; the steward sees systems. Martial arts is the
          medium — the development of mind, body, and discernment is the work.
        </p>
      </div>
      <div class="ph aspect-[16/6] mt-12 reveal">[IMAGE — wide shot of practice in motion / the training space · 16:6 · 1760×660px · focused, calm]</div>
    </div>
  </section>

  <!-- 2. Cohorts: two navy group cards + 4 photo cohort cards -->
  <section id="cohorts" class="bg-stone-200 scroll-mt-24">
    <div class="container-content py-section-sm lg:py-section">
      <div class="text-center max-w-2xl mx-auto mb-12 reveal">
        <div class="flex justify-center mb-4"><HighlightEyebrow mark="One Practice" /></div>
        <h2 class="text-3xl lg:text-4xl">Four Cohorts of Emphasis</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6 mb-6">
        {groups.map(([label, title, blurb, href]) => (
          <div class="reveal bg-navy p-7 lg:p-9 text-center">
            <div class="flex justify-center mb-4"><HighlightEyebrow mark={label} /></div>
            <h3 class="font-display text-3xl text-stone mb-3">{title}</h3>
            <p class="text-stone/70 text-sm max-w-md mx-auto mb-6">{blurb}</p>
            <a href={href} class="btn-ghost !border-stone/40 !text-stone hover:!bg-stone hover:!text-navy">Explore</a>
          </div>
        ))}
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {cohorts.map(([id, name, stage, blurb]) => (
          <div id={id} class="reveal scroll-mt-28">
            <a href={`#${id}`} class="group relative block aspect-[4/5] overflow-hidden bg-navy mb-4">
              <div class="ph absolute inset-0 !rounded-none !border-0 !text-[10px] transition-transform duration-500 group-hover:scale-105">[IMAGE — {name} cohort · 4:5 · 640×800px · candid practice]</div>
              <div class="absolute inset-0 bg-gradient-to-t from-navy/85 via-navy/20 to-transparent"></div>
              <div class="absolute left-4 bottom-4"><HighlightEyebrow mark={stage} /></div>
            </a>
            <h3 class="font-display text-2xl text-navy mb-1">{name}</h3>
            <p class="text-sm text-slate/90">{blurb}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. "More than technique" intro: layered photo pair + ▶ pill (left) + highlight heading + copy + ClaimRotator (right) -->
  <section class="bg-stone">
    <div class="container-content py-section-sm lg:py-section grid lg:grid-cols-2 gap-14 lg:gap-20 items-start">
      <div class="reveal">
        <div class="relative min-h-[420px] lg:min-h-[540px]">
          <ParallaxPhoto
            alt="[IMAGE — focused practice / instruction (primary) · PORTRAIT 4:5 · 1000×1250px]"
            frameClass="aspect-[4/5] w-[78%]"
            parallax={-104}
            innerClass="!text-xs"
          />
          <ParallaxPhoto
            alt="[IMAGE — practice carried outdoors / beyond the floor (secondary) · LANDSCAPE 4:3 · 900×675px]"
            frameClass="absolute -bottom-6 right-0 lg:-right-10 w-[58%] aspect-[4/3] z-20 ring-[10px] ring-stone"
            parallax={-100}
            innerClass="!p-3 !text-[10px]"
          />
        </div>
        <div class="flex justify-start mt-8">
          <button class="group inline-flex items-center gap-3 rounded-full border border-navy/20 bg-white/50 hover:bg-white pl-1.5 pr-5 py-1.5 transition-colors" aria-label="Play: Mind, Body & Discernment">
            <span class="w-9 h-9 rounded-full bg-red flex items-center justify-center shrink-0 transition-transform duration-200 group-hover:scale-110">
              <svg width="10" height="12" viewBox="0 0 10 12" class="text-stone ml-0.5" fill="currentColor"><polygon points="0,0 10,6 0,12" /></svg>
            </span>
            <span class="font-accent text-sm tracking-wide text-navy">Mind, Body &amp; Discernment</span>
          </button>
        </div>
      </div>
      <div class="reveal">
        <p class="font-accent uppercase tracking-[0.14em] text-xl lg:text-2xl text-navy mb-7 inline-flex flex-wrap items-center gap-x-2.5 gap-y-1">
          <span>More Than</span><span class="bg-red text-stone px-2 py-0.5">Technique</span>
        </p>
        <p class="text-slate/90 leading-relaxed mb-8">
          The practice asks the student to adopt a multidisciplinary approach: the work is not finished by
          excelling on the training floor alone. Mind, body, and discernment are developed together, and the
          result is meant to be carried into every system the student moves within.
        </p>
        <GoldArrowLink href="/about/ethos" text="The Founding Principles" class="mb-10" />
        <ClaimRotator items={claims} dark={false} label="What the practice develops" />
      </div>
    </div>
  </section>

  <!-- 4. The Constitutional Framework: segmented wheel + 7-row disclosure accordion -->
  <section id="framework" class="bg-stone-200 scroll-mt-24">
    <div class="container-content py-section-sm lg:py-section">
      <div class="text-center max-w-2xl mx-auto mb-12 reveal">
        <h2 class="text-3xl lg:text-4xl">The Constitutional Framework</h2>
        <p class="text-slate/80 mt-3">Principles that govern all practice.</p>
      </div>
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="reveal flex justify-center">
          <div class="relative w-[min(420px,90vw)] aspect-square rounded-full" style={`background: conic-gradient(${wheelStops});`}>
            <div class="absolute inset-[26%] rounded-full bg-stone-200 flex items-center justify-center text-center">
              <span class="font-display text-navy text-lg leading-tight px-4">The Practice<br />of Participation</span>
            </div>
            {wheelLabels.map((l) => (
              <span
                class="absolute -translate-x-1/2 -translate-y-1/2 font-accent text-[10px] lg:text-xs uppercase tracking-wide text-stone font-semibold text-center w-16 leading-tight"
                style={`left:${l.x}%; top:${l.y}%;`}
              >{l.name}</span>
            ))}
          </div>
        </div>
        <div class="reveal">
          <p class="text-slate/80 mb-5">Aspirational and inspirational development through:</p>
          <div class="divide-y divide-navy/10 border-t border-b border-navy/10">
            {framework.map(([name, desc], i) => (
              <details class="group" open={i === 0}>
                <summary class="flex items-center justify-between gap-4 py-4 cursor-pointer list-none">
                  <span class="font-accent uppercase tracking-wide text-navy">{name}</span>
                  <span class="text-navy/40 group-open:rotate-45 transition-transform text-2xl leading-none" aria-hidden="true">+</span>
                </summary>
                <p class="pb-4 text-slate/90">{desc}</p>
              </details>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. "Go Deeper" hub: how the practice is delivered -->
  <section id="programs" class="bg-stone scroll-mt-24">
    <div class="container-content py-section-sm lg:py-section">
      <div class="text-center max-w-2xl mx-auto mb-12 reveal">
        <div class="flex justify-center mb-4"><HighlightEyebrow mark="Go Deeper" /></div>
        <h2 class="text-3xl lg:text-4xl">How the Practice Is Delivered</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4">
        {programs.map(([label, href, alt]) => (
          <div class="reveal"><PhotoNavCard label={label} href={href} alt={alt} center /></div>
        ))}
      </div>
    </div>
  </section>

  <Cta />
</Base>
