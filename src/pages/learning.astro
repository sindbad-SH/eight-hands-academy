---
// LEARNING — reference archetype A (Landing/overview), structure VERIFIED by live Chrome audit of
// aiglon.ch/learning (2026-06-05). Section order (6 blocks), re-skinned for the Qi-House:
//   1. header band: red-pill eyebrow + H1 + centered intro + wide image
//   2. cohorts: eyebrow + heading + two NAVY group cards + 4 photo cohort cards (red-pill stage label)
//   3. "More than technique": layered photo pair + ▶ pill (left) + highlight heading + copy + ClaimRotator (right)
//   4. The Framework: heading + two-column (segmented wheel diagram + 7-row disclosure ACCORDION)
//   5. "Go Deeper" hub: red-pill eyebrow + heading + photo-card grid (centered titles)
//   + closing CTA
import Base from '../layouts/Base.astro';
import SectionSubnav from '../components/SectionSubnav.astro';
import HighlightEyebrow from '../components/HighlightEyebrow.astro';
import GoldArrowLink from '../components/GoldArrowLink.astro';
import ParallaxPhoto from '../components/ParallaxPhoto.astro';
import ClaimRotator from '../components/ClaimRotator.astro';
import PhotoNavCard from '../components/PhotoNavCard.astro';
import Cta from '../components/Cta.astro';
import { withBase } from '../data/site';
import { learningSubnav } from '../data/nav';

// The four development stages → their detail pages (Jeanette's 2026-06-06 Learning copy).
const path: [string, string, string][] = [
  ['Observe', 'Awareness creates possibility.', '/learning/observe'],
  ['Practice', 'Action develops capability.', '/learning/practice'],
  ['Integrate', 'Consistency transforms knowledge into character.', '/learning/integrate'],
  ['Contribute', 'Leadership begins when development serves others.', '/learning/contribute'],
];

// Two group cards (reference: Junior/Senior School) → the two pillars of the educational model.
const groups = [
  ['Education', 'Individualized Instruction', 'Where the teaching happens — one-on-one work that builds confidence, focus, and self-governance at each student’s own pace.', '/learning/individualized-instruction'],
  ['Application', 'Group Instruction', 'The application laboratory — where developing skills are tested with others, building communication, accountability, and resilience.', '/learning/group-instruction'],
];

// Three enrollment pathways (reskin-map §3.2). Recommended after an assessment — not chosen off a menu.
const cohorts: [string, string, string, string, string][] = [
  ['membership', 'Academy Membership', 'Foundation', 'The starting pathway: structured private instruction plus group application, building discipline, focus, and confidence from the ground up.', '/img/instruction-1.jpg'],
  ['scholar', 'Academy Scholar', 'Advancing', 'For the committed student: a deeper course of study that develops awareness, discernment, and accountability across every part of the practice.', '/img/reflection-2.jpg'],
  ['fellow', 'Academy Fellow', 'By Invitation', 'Extended to advanced students ready to lead — the leadership track where capability is expressed by guiding and developing others.', '/img/mentoring-1.jpg'],
  ['recommended', 'A Recommended Path', 'After Assessment', 'Membership establishes a student’s place within the academy. Educational pathways determine how they develop within it.', '/img/exterior-wide.jpg'],
];

// Rotating claims for the "More than technique" intro card (reference: panel-05 rotating claim card).
const claims: [string, string][] = [
  ['An Education, Not a Belt Mill', 'Progress is measured in confidence, discipline, and accountability — not by collecting rank.'],
  ['Mind, Body & Discernment', 'Focus, resilience, and clear judgment are developed together; none advanced at the expense of another.'],
  ['Carried Beyond the Floor', 'What you build here is meant to govern how you participate in every part of your life.'],
  ['Pathways, Not Pressure', 'We recommend the right course of study for your goals — we do not push a sale.'],
];

// The 7-principle development framework (reskin-map §3.2) — a disclosure accordion + a segmented wheel.
// Framed plainly as the outcomes the education develops (de-esoterica: no realms/houses).
const framework: [string, string][] = [
  ['Confidence', 'A grounded sense of your own capability — the steadiness to act rather than hesitate.'],
  ['Focus', 'The ability to stay present and give your full attention to what matters, without drifting.'],
  ['Awareness', 'Clear perception of yourself, of others, and of the situation you are actually in.'],
  ['Discernment', 'Sound judgment under real conditions — knowing what to do with what you notice.'],
  ['Accountability', 'Ownership of your choices and their consequences, claimed rather than assigned.'],
  ['Resilience', 'The developed capacity to perform, recover, and keep your footing when it is hard.'],
  ['Leadership', 'The ability to govern yourself first, then contribute responsibly to those around you.'],
];

// Build the segmented framework wheel (7 equal arcs, cycling navy/red/gold) + label positions.
const wheelColors = ['#0B2341', '#8C1D18', '#C39A3C'];
const segDeg = 360 / framework.length;
const wheelStops = framework
  .map((_, i) => `${wheelColors[i % 3]} ${(i * segDeg).toFixed(2)}deg ${((i + 1) * segDeg).toFixed(2)}deg`)
  .join(', ');
const wheelLabels = framework.map(([name], i) => {
  const a = ((i + 0.5) * segDeg - 90) * (Math.PI / 180);
  const r = 36; // % from center
  return { name, x: (50 + r * Math.cos(a)).toFixed(1), y: (50 + r * Math.sin(a)).toFixed(1) };
});
// Cream divider lines between all 7 segments — so adjacent same-color arcs (e.g. Leadership & Confidence,
// both navy where the 3-color cycle wraps) read as clearly separate sections.
const wheelDividers = framework.map((_, i) => {
  const t = (i * segDeg) * (Math.PI / 180);
  const s = Math.sin(t), c = Math.cos(t);
  return { x1: (50 + 25 * s).toFixed(2), y1: (50 - 25 * c).toFixed(2), x2: (50 + 50 * s).toFixed(2), y2: (50 - 50 * c).toFixed(2) };
});

// "Go Deeper / How We Learn" hub — the educational model (reskin-map §3.2).
// Private = Education · Group = Application Laboratory · Leadership = Advanced Application.
const programs: [string, string, string, string][] = [
  ['Individualized Instruction — The Core', '/learning/individualized-instruction', '[IMAGE — one-on-one instruction, mentor + student · 4:3 · 760×570px]', '/img/instruction-3.jpg'],
  ['Group Instruction — The Application', '/learning/group-instruction', '[IMAGE — group practice on the floor, candid · 4:3 · 760×570px]', '/img/group-2.jpg'],
  ['Leadership — Advanced Application', '/community/instructor-development', '[IMAGE — advanced student guiding / leading others · 4:3 · 760×570px]', '/img/mentoring-2.jpg'],
  ['Your Assessment — Where to Begin', '/learning#cohorts', '[IMAGE — calm one-on-one conversation, welcoming · 4:3 · 760×570px]', '/img/community-1.jpg'],
];
---
<Base home title="Learning at the Qi-House" description="An education in participation — martial arts as the medium.">
  <SectionSubnav items={learningSubnav} active="/learning" label="Learning section" />

  <!-- 1. Header band -->
  <section class="bg-stone">
    <div class="container-content py-section-sm lg:py-section">
      <div class="text-center max-w-3xl mx-auto reveal">
        <div class="flex justify-center mb-5"><HighlightEyebrow mark="A Martial Arts Education" /></div>
        <h1 class="text-4xl lg:text-5xl text-navy mb-6">Learning at the Qi-House</h1>
        <p class="text-slate/90 text-lg leading-relaxed">
          Students leave with confidence, focus, and the discipline to govern themselves — the outcomes that
          carry into school, work, and home. Martial arts is the medium; the real work is developing the
          awareness, resilience, and accountability of a person who can lead themselves before influencing others.
        </p>
      </div>
      <div class="relative aspect-[16/9] mt-12 reveal overflow-hidden"><img src={withBase('/img/environment-1.jpg')} alt="The Qi-House training space" loading="lazy" class="absolute inset-0 w-full h-full object-cover" /></div>
    </div>
  </section>

  <!-- 2. Cohorts: two navy group cards + 4 photo cohort cards -->
  <section id="cohorts" class="bg-stone-200 scroll-mt-24">
    <div class="container-content py-section-sm lg:py-section">
      <div class="text-center max-w-2xl mx-auto mb-12 reveal">
        <div class="flex justify-center mb-4"><HighlightEyebrow mark="Educational Pathways" /></div>
        <h2 class="text-3xl lg:text-4xl">How Students Enroll &amp; Advance</h2>
        <p class="text-slate/80 mt-3">Two ways the education is delivered, and the pathways we may recommend after your assessment.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-6 mb-6">
        {groups.map(([label, title, blurb, href]) => (
          <div class="reveal bg-navy p-7 lg:p-9 text-center">
            <div class="flex justify-center mb-4"><HighlightEyebrow mark={label} /></div>
            <h3 class="font-display text-3xl text-stone mb-3">{title}</h3>
            <p class="text-stone/70 text-sm max-w-md mx-auto mb-6">{blurb}</p>
            <a href={withBase(href)} class="btn-ghost !border-stone/40 !text-stone hover:!bg-stone hover:!text-navy">Explore</a>
          </div>
        ))}
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {cohorts.map(([id, name, stage, blurb, img]) => (
          <div id={id} class="reveal scroll-mt-28">
            <a href={`#${id}`} class="group relative block aspect-[4/5] overflow-hidden bg-navy mb-4">
              <img src={withBase(img)} alt={name} loading="lazy" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
              <div class="absolute inset-0 bg-gradient-to-t from-navy/85 via-navy/20 to-transparent"></div>
              <div class="absolute left-4 bottom-4"><HighlightEyebrow mark={stage} /></div>
            </a>
            <h3 class="font-display text-2xl text-navy mb-1">{name}</h3>
            <p class="text-sm text-slate/90">{blurb}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. "More than technique" intro: layered photo pair + ▶ pill (left) + highlight heading + copy + ClaimRotator (right) -->
  <section class="bg-stone">
    <div class="container-content py-section-sm lg:py-section grid lg:grid-cols-2 gap-14 lg:gap-20 items-start">
      <div class="reveal lg:order-2">
        <div class="relative min-h-[300px] lg:min-h-[400px]">
          <ParallaxPhoto
            img="/img/form-1.jpg"
            alt="[IMAGE — focused practice / instruction (primary) · LANDSCAPE 4:3 · 1000×750px]"
            frameClass="aspect-[4/3] w-[88%]"
            parallax={-104}
            innerClass="!text-xs"
          />
          <ParallaxPhoto
            img="/img/service-1.jpg"
            alt="[IMAGE — practice carried outdoors / beyond the floor (secondary) · LANDSCAPE 4:3 · 900×675px]"
            frameClass="absolute -bottom-6 right-0 lg:-right-10 w-[58%] aspect-[4/3] z-20 ring-[10px] ring-stone"
            parallax={-100}
            innerClass="!p-3 !text-[10px]"
          />
        </div>
        <div class="flex justify-start mt-8">
          <button class="group inline-flex items-center gap-3 rounded-full border border-navy/20 bg-white/50 hover:bg-white pl-1.5 pr-5 py-1.5 transition-colors" aria-label="Play: Mind, Body & Discernment">
            <span class="w-9 h-9 rounded-full bg-red flex items-center justify-center shrink-0 transition-transform duration-200 group-hover:scale-110">
              <svg width="10" height="12" viewBox="0 0 10 12" class="text-stone ml-0.5" fill="currentColor"><polygon points="0,0 10,6 0,12" /></svg>
            </span>
            <span class="font-accent text-sm tracking-wide text-navy">Mind, Body &amp; Discernment</span>
          </button>
        </div>
      </div>
      <div class="reveal lg:order-1">
        <p class="font-accent uppercase tracking-[0.14em] text-xl lg:text-2xl text-navy mb-7 inline-flex flex-wrap items-center gap-x-2.5 gap-y-1">
          <span>More Than</span><span class="bg-red text-stone px-2 py-0.5">Technique</span>
        </p>
        <p class="text-slate/90 leading-relaxed mb-8">
          The skills students build here are not finished on the training floor. Confidence, focus, and sound
          judgment are developed together — mind, body, and discernment at once — so the discipline carries
          into how a student shows up at school, at work, and at home. The outcome is a person better able to
          govern themselves.
        </p>
        <GoldArrowLink href="/about/ethos" text="Why Eight Hands" class="mb-10" />
        <ClaimRotator items={claims} dark={false} label="What the practice develops" />
      </div>
    </div>
  </section>

  <!-- 3b. The Development Path: four stage cards → detail pages (Observe → Practice → Integrate → Contribute) -->
  <section id="path" class="bg-stone scroll-mt-24">
    <div class="container-content py-section-sm lg:py-section">
      <div class="text-center max-w-2xl mx-auto mb-12 reveal">
        <div class="flex justify-center mb-4"><HighlightEyebrow mark="The Development Path" /></div>
        <h2 class="text-3xl lg:text-4xl">How Students Develop</h2>
        <p class="text-slate/80 mt-3">Four stages every student moves through — each one building on the last.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {path.map(([name, tagline, href], i) => (
          <a href={withBase(href)} class="reveal group block border border-navy/10 bg-white p-6 hover:border-gold hover:-translate-y-1 transition-all duration-200">
            <div class="font-accent text-[11px] uppercase tracking-[0.16em] text-red mb-2">Step {i + 1}</div>
            <h3 class="font-display text-2xl text-navy mb-2">{name}</h3>
            <p class="text-slate/80 text-sm mb-4">{tagline}</p>
            <span class="font-accent text-[11px] uppercase tracking-[0.16em] text-gold-600 group-hover:text-gold transition-colors">Explore →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. The Constitutional Framework: segmented wheel + 7-row disclosure accordion -->
  <section id="framework" class="bg-stone-200 scroll-mt-24">
    <div class="container-content py-section-sm lg:py-section">
      <div class="text-center max-w-2xl mx-auto mb-12 reveal">
        <h2 class="text-3xl lg:text-4xl">What the Education Develops</h2>
        <p class="text-slate/80 mt-3">Seven outcomes every student builds through the practice.</p>
      </div>
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="reveal flex justify-center lg:order-2">
          <div class="relative w-[min(420px,90vw)] aspect-square rounded-full overflow-hidden" style={`background: conic-gradient(${wheelStops});`}>
            <svg viewBox="0 0 100 100" class="absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true">
              {wheelDividers.map((d) => <line x1={d.x1} y1={d.y1} x2={d.x2} y2={d.y2} stroke="#F8F6F2" stroke-width="0.7" opacity="0.9" />)}
            </svg>
            <div class="absolute inset-[26%] rounded-full bg-stone-200 flex items-center justify-center text-center z-10 ring-2 ring-stone/70">
              <span class="font-display text-navy text-lg leading-tight px-4">Self-<br />Governance</span>
            </div>
            {wheelLabels.map((l) => (
              <span
                class="absolute -translate-x-1/2 -translate-y-1/2 z-10 font-accent text-[10px] uppercase tracking-tight text-stone font-semibold text-center w-24 leading-[1.1] [text-shadow:0_1px_3px_rgba(11,35,65,0.9)]"
                style={`left:${l.x}%; top:${l.y}%;`}
              >{l.name}</span>
            ))}
          </div>
        </div>
        <div class="reveal lg:order-1">
          <p class="text-slate/80 mb-5">Each outcome is developed deliberately, one capability building on the next:</p>
          <div class="divide-y divide-navy/10 border-t border-b border-navy/10">
            {framework.map(([name, desc], i) => (
              <details class="group" open={i === 0}>
                <summary class="flex items-center justify-between gap-4 py-4 cursor-pointer list-none">
                  <span class="font-accent uppercase tracking-wide text-navy">{name}</span>
                  <span class="text-navy/40 group-open:rotate-45 transition-transform text-2xl leading-none" aria-hidden="true">+</span>
                </summary>
                <p class="pb-4 text-slate/90">{desc}</p>
              </details>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. "Go Deeper" hub: how the practice is delivered -->
  <section id="programs" class="bg-stone scroll-mt-24">
    <div class="container-content py-section-sm lg:py-section">
      <div class="text-center max-w-2xl mx-auto mb-12 reveal">
        <div class="flex justify-center mb-4"><HighlightEyebrow mark="The Educational Model" /></div>
        <h2 class="text-3xl lg:text-4xl">How the Education Is Delivered</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4">
        {programs.map(([label, href, alt, img]) => (
          <div class="reveal"><PhotoNavCard label={label} href={href} alt={alt} img={img} center /></div>
        ))}
      </div>
    </div>
  </section>

  <Cta />
</Base>
