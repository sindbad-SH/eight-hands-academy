---
// Site header — sticky white header on sub-pages; reveal-on-scroll header on the homepage
// (the navy in-flow home header is HomeHeader.astro). Nav data shared via data/nav.
import { nav } from '../data/nav';
import { BOOKING_URL, withBase } from '../data/site';

interface Props {
  reveal?: boolean; // homepage: start hidden, slide/fade in once scrolled past the hero
}
const { reveal = false } = Astro.props;
---

<header
  id="siteHeader"
  data-reveal={reveal ? 'true' : 'false'}
  class:list={[
    'z-50 border-b border-navy/10 transition-all duration-300 ease-out',
    reveal
      ? 'fixed top-0 left-0 right-0 bg-stone shadow-md -translate-y-full opacity-0 pointer-events-none'
      : 'sticky top-0 bg-stone/95 backdrop-blur supports-[backdrop-filter]:bg-stone/80',
  ]}
>
  <!-- Logo LEFT; right side = utility row (top) + main nav (below), both right-aligned. CTA in utility row. -->
  <div class="container-content flex items-start justify-between gap-6 py-3">
    <a href={withBase('/')} class="flex items-center gap-3 shrink-0">
      <img src={withBase('/img/logo.png')} alt="Eight Hands emblem" class="h-16 w-auto" />
      <span class="flex flex-col leading-none pt-0.5">
        <span class="font-display text-2xl font-semibold text-navy">Eight Hands</span>
        <span class="eyebrow !text-slate-400 mt-0.5">Martial Arts Academy</span>
      </span>
    </a>

    <div class="hidden lg:flex flex-col items-end gap-2.5">
      <!-- Utility row -->
      <div class="flex items-center gap-4 text-[11px] font-accent tracking-wide text-slate">
        <a href={withBase('/community/summer-academy')} class="inline-flex items-center gap-1.5 hover:text-navy transition-colors">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.5 1.5M17.5 17.5L19 19M19 5l-1.5 1.5M6.5 17.5L5 19" /></svg>
          Summer Academy
        </a>
        <a href={withBase('/community/alumni')} class="inline-flex items-center gap-1.5 hover:text-navy transition-colors">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 11l9-5 9 5-9 5-9-5z" /><path d="M7 13v4c0 1 2 2 5 2s5-1 5-2v-4" /></svg>
          Alumni
        </a>
        <a href={withBase('/community/impact')} class="inline-flex items-center gap-1.5 hover:text-navy transition-colors">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 21s-7-4.5-9-9C1.5 8 4 4 8 5c2 .5 3 2 4 3 1-1 2-2.5 4-3 4-1 6.5 3 5 7-2 4.5-9 9-9 9z" /></svg>
          Support
        </a>
        <a href={BOOKING_URL} target="_blank" rel="noopener" class="btn-accent !py-1.5 !px-4 !text-[11px] uppercase">Schedule an Assessment</a>
        <a href={withBase('/members')} class="border border-navy/25 px-3 py-1.5 rounded-[10px] uppercase text-navy/80 hover:border-gold transition-colors">Members</a>
        <button data-search-open aria-label="Search" class="hover:text-navy transition-colors">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7" /><path d="M21 21l-4-4" /></svg>
        </button>
      </div>

      <!-- Main nav row (right-aligned) -->
      <nav class="flex items-center gap-7">
        {nav.map((item) => (
          <div class="group relative">
            <a href={withBase(item.href)} class="font-accent text-sm font-medium uppercase tracking-wide text-navy/90 hover:text-navy py-1.5 inline-flex items-center">
              {item.label}
            </a>
            <!-- Dropdown (measured on the reference): single narrow PORTRAIT column (~280×439), white panel
                 with a RED top accent line, light hairline dividers between items, item text turns RED on hover. -->
            <div class="dd absolute right-0 top-full invisible opacity-0 w-[260px] bg-stone border-t-2 border-red shadow-md z-30 divide-y divide-navy/10 transition-all duration-150">
              {item.children.map(([label, href]) => (
                <a href={withBase(href)} class="block px-5 py-2.5 text-sm text-slate hover:text-red transition-colors">{label}</a>
              ))}
            </div>
          </div>
        ))}
      </nav>
    </div>

    <button id="mobileToggle" class="lg:hidden text-navy self-center" aria-label="Open menu" aria-expanded="false">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div id="mobileMenu" class="lg:hidden hidden border-t border-navy/10 bg-stone">
    <nav class="container-content py-4 flex flex-col">
      {nav.map((item) => (
        <details class="border-b border-navy/10 py-1">
          <summary class="font-accent text-sm font-medium text-navy py-2 cursor-pointer list-none flex justify-between">
            {item.label}<span aria-hidden="true">+</span>
          </summary>
          <div class="pl-3 pb-2 flex flex-col">
            {item.children.map(([label, href]) => (
              <a href={withBase(href)} class="py-1.5 text-sm text-slate">{label}</a>
            ))}
          </div>
        </details>
      ))}
      <a href={BOOKING_URL} target="_blank" rel="noopener" class="btn-accent mt-4 w-full">Schedule an Assessment</a>
    </nav>
  </div>

  <script>
    const toggle = document.getElementById('mobileToggle');
    const menu = document.getElementById('mobileMenu');
    toggle?.addEventListener('click', () => {
      const open = menu?.classList.toggle('hidden');
      toggle.setAttribute('aria-expanded', String(open === false));
    });

    // Reveal-on-scroll (homepage): show once scrolled past the hero, hide near the top.
    const header = document.getElementById('siteHeader');
    if (header && header.dataset.reveal === 'true') {
      const hiddenCls = ['-translate-y-full', 'opacity-0', 'pointer-events-none'];
      const onScroll = () => {
        const show = window.scrollY > 500;
        hiddenCls.forEach((c) => header.classList.toggle(c, !show));
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }

    // Nav dropdowns: hover-open with a short close delay; only one open at a time (prevents stacking).
    (() => {
      const groups = [...document.querySelectorAll('#siteHeader nav .group')];
      let t: ReturnType<typeof setTimeout>;
      const hide = (g: Element) => { const d = g.querySelector('.dd'); if (!d) return; d.classList.add('invisible', 'opacity-0'); d.classList.remove('opacity-100', 'visible'); };
      const show = (g: Element) => { groups.forEach((o) => { if (o !== g) hide(o); }); const d = g.querySelector('.dd'); if (!d) return; d.classList.remove('invisible', 'opacity-0'); d.classList.add('opacity-100', 'visible'); };
      groups.forEach((g) => {
        g.addEventListener('mouseenter', () => { clearTimeout(t); show(g); });
        g.addEventListener('mouseleave', () => { t = setTimeout(() => hide(g), 260); });
        g.addEventListener('focusin', () => { clearTimeout(t); show(g); });
        g.addEventListener('focusout', () => { t = setTimeout(() => hide(g), 220); });
      });
    })();
  </script>
</header>
