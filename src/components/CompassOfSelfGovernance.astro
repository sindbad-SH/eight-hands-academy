---
// "The Compass of Self-Governance" — replaces the homepage StatMap. Restyled to match the client's reference
// IMAGE (viewed via her ChatGPT share link, 2026-06-06): dimensional gold compass rose, FLOATING gold text
// labels + node dots (no chips), HOVER → offset white micro-card (Title + Kanji + summary + Learn More),
// CLICK → DARK-navy educational sidebar (Kanji red, gold title, gold section labels, gold-outline Related
// Programs). All point content is HER copy. (Her text spec said a *white* sidebar; her image shows *dark* —
// matched the image, which is also more on-brand. A coded/interactive vector take on her raster reference.)
import TopoTexture from './TopoTexture.astro';

const points = [
  { name: 'Purpose', kanji: '目的', summary: 'Align action with meaning.',
    definition: 'Purpose is the ability to align actions with meaning and long-term direction.',
    focus: ['Vision', 'Values', 'Legacy', 'Contribution'], outcomes: ['Direction', 'Motivation', 'Meaning'],
    applications: 'Goal setting, leadership, career planning, service.' },
  { name: 'Mind', kanji: '心智', summary: 'Clarity sharpens every choice.',
    definition: 'Mind represents awareness, clarity, understanding, and learning.',
    focus: ['Focus', 'Critical Thinking', 'Awareness', 'Learning'], outcomes: ['Better decisions', 'Mental clarity', 'Adaptability'],
    applications: 'Academics, leadership, communication, problem solving.' },
  { name: 'Discipline', kanji: '形成', summary: 'Habits shape destiny.',
    definition: 'Discipline is the daily commitment to what matters most.',
    focus: ['Consistency', 'Self-Control', 'Time Management', 'Follow Through'], outcomes: ['Reliability', 'Confidence', 'Achievement'],
    applications: 'Training, study, work, relationships.' },
  { name: 'Communication', kanji: '伝達', summary: 'Understand, connect, convey.',
    definition: 'Communication is the ability to understand, connect, and convey meaning effectively.',
    focus: ['Listening', 'Speaking', 'Connection', 'Influence'], outcomes: ['Better relationships', 'Leadership presence', 'Conflict reduction'],
    applications: 'Family, business, teaching, teamwork.' },
  { name: 'Courage', kanji: '勇気', summary: 'Act well despite fear.',
    definition: 'Courage is taking appropriate action despite uncertainty or fear.',
    focus: ['Initiative', 'Resilience', 'Adaptability', 'Action'], outcomes: ['Confidence', 'Persistence', 'Growth'],
    applications: 'Public speaking, leadership, conflict, challenge.' },
  { name: 'Body', kanji: '身体', summary: 'Capability, trained and expressed.',
    definition: 'The body is the vehicle through which discipline, health, and capability are expressed.',
    focus: ['Strength', 'Mobility', 'Conditioning', 'Self-Defense'], outcomes: ['Physical confidence', 'Health', 'Capability'],
    applications: 'Martial arts, athletics, daily life.' },
  { name: 'Service', kanji: '奉仕', summary: 'Create value beyond yourself.',
    definition: 'Service is the commitment to creating value beyond oneself.',
    focus: ['Contribution', 'Stewardship', 'Responsibility', 'Compassion'], outcomes: ['Empathy', 'Leadership', 'Community impact'],
    applications: 'Family, community, mentorship.' },
  { name: 'Leadership', kanji: '指導', summary: 'Guide yourself, then others.',
    definition: 'Leadership is the ability to guide yourself and others toward a shared vision.',
    focus: ['Accountability', 'Influence', 'Stewardship', 'Initiative'], outcomes: ['Responsibility', 'Presence', 'Decision Making'],
    applications: 'Teams, business, education, family.' },
];
const placed = points.map((p, i) => {
  const a = (i * 45 - 90) * (Math.PI / 180);
  const y = 50 + 41 * Math.sin(a);
  return { ...p, x: (50 + 41 * Math.cos(a)).toFixed(2), y: y.toFixed(2), below: y >= 50 };
});
const cardinals = [0, 90, 180, 270];
const diagonals = [45, 135, 225, 315];
const ticks = Array.from({ length: 24 }, (_, i) => {
  const a = i * 15 * (Math.PI / 180);
  const r1 = i % 6 === 0 ? 80 : 86;
  return { x1: (100 + r1 * Math.cos(a)).toFixed(2), y1: (100 + r1 * Math.sin(a)).toFixed(2), x2: (100 + 92 * Math.cos(a)).toFixed(2), y2: (100 + 92 * Math.sin(a)).toFixed(2) };
});
---
<section class="bg-navy text-stone relative overflow-hidden">
  <TopoTexture id="topo-compass" />
  <div class="container-content relative z-10 py-section text-center">
    <div class="max-w-2xl mx-auto reveal">
      <h2 class="text-3xl lg:text-4xl text-stone mb-5">Development With Direction</h2>
      <p class="text-stone/80 font-display italic text-xl leading-relaxed">
        The Compass of Self-Governance guides students in developing mind, body, and spirit through purposeful
        practice, individualized education, and personal responsibility.
      </p>
      <p class="mt-6 font-accent uppercase tracking-[0.16em] text-[10px] sm:text-xs text-gold/80 leading-relaxed">
        {points.map((p) => p.name).join('  ·  ')}
      </p>
      <p class="mt-3 text-stone/40 text-xs italic">Hover a point for a glimpse — click it to explore.</p>
    </div>

    <!-- DESKTOP/TABLET compass: dimensional rose + 8 floating labels -->
    <div class="relative mx-auto mt-12 lg:mt-16 w-[min(680px,92vw)] aspect-square reveal hidden sm:block">
      <svg viewBox="0 0 200 200" class="absolute inset-[16%]" aria-hidden="true">
        <defs>
          <linearGradient id="goldFace" x1="0" y1="0" x2="0.9" y2="1">
            <stop offset="0" stop-color="#E8CB80" /><stop offset="1" stop-color="#9C7C30" />
          </linearGradient>
        </defs>
        <g fill="none" stroke="#C39A3C">
          <circle cx="100" cy="100" r="94" stroke-width="0.5" opacity="0.7" />
          <circle cx="100" cy="100" r="74" stroke-width="0.4" opacity="0.35" />
          <circle cx="100" cy="100" r="50" stroke-width="0.4" opacity="0.25" />
          <circle cx="100" cy="100" r="8" stroke-width="0.8" opacity="0.9" />
        </g>
        <g stroke="#C39A3C" stroke-width="0.5" opacity="0.45">
          {ticks.map((t) => <line x1={t.x1} y1={t.y1} x2={t.x2} y2={t.y2} />)}
        </g>
        <!-- long faceted cardinal points (lit half / shadow half) -->
        {cardinals.map((d) => (
          <g transform={`rotate(${d} 100 100)`}>
            <polygon points="100,9 100,100 94,100" fill="url(#goldFace)" />
            <polygon points="100,9 106,100 100,100" fill="#6E551E" />
          </g>
        ))}
        <!-- medium diagonal points -->
        {diagonals.map((d) => (
          <g transform={`rotate(${d} 100 100)`}>
            <polygon points="100,44 100,100 96,100" fill="url(#goldFace)" opacity="0.85" />
            <polygon points="100,44 104,100 100,100" fill="#5e4818" opacity="0.9" />
          </g>
        ))}
        <circle cx="100" cy="100" r="5" fill="#C39A3C" />
      </svg>

      {placed.map((p, i) => (
        <div
          class="compass-pt group absolute -translate-x-1/2 -translate-y-1/2 z-10 hover:z-30 cursor-pointer"
          style={`left:${p.x}%; top:${p.y}%;`}
          data-i={i}
          role="button"
          tabindex="0"
          aria-label={`Explore ${p.name}`}
        >
          <span class="block w-1.5 h-1.5 rounded-full bg-gold mx-auto mb-1.5 transition-all group-hover:bg-red group-hover:ring-4 group-hover:ring-red/25"></span>
          <span class="font-accent uppercase tracking-[0.16em] text-[11px] lg:text-xs text-gold/90 group-hover:text-gold transition-colors whitespace-nowrap">{p.name}</span>
          <!-- offset white micro-card on hover -->
          <div class:list={['pointer-events-none absolute left-1/2 -translate-x-1/2 w-44 bg-stone shadow-xl border-l-4 border-l-red px-4 py-3 text-left opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-40', p.below ? 'top-full mt-3' : 'bottom-full mb-3']}>
            <div class="flex items-center justify-between gap-2">
              <span class="font-accent uppercase tracking-wide text-[11px] text-navy">{p.name}</span>
              <span class="font-display text-lg text-red leading-none">{p.kanji}</span>
            </div>
            <p class="text-[11px] leading-snug text-slate mt-1.5">{p.summary}</p>
            <span class="block font-accent text-[10px] uppercase tracking-wide text-red mt-2">Learn More →</span>
          </div>
        </div>
      ))}
    </div>

    <!-- MOBILE: tappable list (opens the sidebar) -->
    <div class="sm:hidden mt-10 grid grid-cols-2 gap-3 reveal">
      {points.map((p, i) => (
        <button type="button" class="compass-pt border border-gold/40 bg-navy/50 px-3 py-3 text-center" data-i={i} aria-label={`Explore ${p.name}`}>
          <span class="block font-display text-xl text-gold leading-none mb-1">{p.kanji}</span>
          <span class="font-accent uppercase tracking-[0.08em] text-[10px] text-stone">{p.name}</span>
        </button>
      ))}
    </div>
  </div>

  <!-- Click-to-open educational sidebar (dark navy, per the reference image) -->
  <div id="compassOverlay" class="fixed inset-0 z-[90] bg-navy/70 opacity-0 pointer-events-none transition-opacity duration-300"></div>
  <aside id="compassPanel" class="fixed top-0 right-0 z-[95] h-full w-full sm:w-[38%] sm:min-w-[360px] max-w-[440px] bg-navy-900 text-stone shadow-2xl border-l-4 border-l-red translate-x-full transition-transform duration-300 ease-out overflow-y-auto" aria-hidden="true" aria-label="Compass detail">
    <div class="p-8 lg:p-10">
      <button id="compassClose" class="absolute right-5 top-5 text-stone/50 hover:text-stone text-3xl leading-none" aria-label="Close">&times;</button>
      <div id="compassPanelBody"></div>
    </div>
  </aside>

  <script type="application/json" id="compassData" set:html={JSON.stringify(points)}></script>
  <script>
    const data = JSON.parse(document.getElementById('compassData')?.textContent || '[]');
    const panel = document.getElementById('compassPanel');
    const overlay = document.getElementById('compassOverlay');
    const body = document.getElementById('compassPanelBody');
    const li = (arr: string[]) => arr.map((x) => `<li class="flex gap-2"><span class="text-red">·</span>${x}</li>`).join('');
    const open = (p: any) => {
      if (body) body.innerHTML = `
        <h3 class="font-accent uppercase tracking-[0.18em] text-gold text-xl">${p.name}</h3>
        <div class="font-display text-4xl text-red mt-1 mb-3">${p.kanji}</div>
        <div class="w-12 h-px bg-gold/50 mb-6"></div>
        <p class="text-stone/80 leading-relaxed mb-7">${p.definition}</p>
        <div class="mb-6"><div class="font-accent uppercase tracking-[0.16em] text-[11px] text-gold/70 mb-2">Development Focus</div><ul class="space-y-1 text-sm text-stone/90">${li(p.focus)}</ul></div>
        <div class="mb-6"><div class="font-accent uppercase tracking-[0.16em] text-[11px] text-gold/70 mb-2">Student Outcomes</div><ul class="space-y-1 text-sm text-stone/90">${li(p.outcomes)}</ul></div>
        <div class="mb-7"><div class="font-accent uppercase tracking-[0.16em] text-[11px] text-gold/70 mb-2">Applications</div><p class="text-sm text-stone/75">${p.applications}</p></div>
        <div><div class="font-accent uppercase tracking-[0.16em] text-[11px] text-gold/70 mb-3">Related Programs</div><a href="/learning" class="inline-flex items-center gap-2 border border-gold/50 text-gold hover:bg-gold hover:text-navy transition-colors rounded-[10px] px-4 py-2 font-accent text-xs uppercase tracking-wide">Academy Pathways →</a></div>`;
      panel?.classList.remove('translate-x-full');
      overlay?.classList.remove('opacity-0', 'pointer-events-none');
      panel?.setAttribute('aria-hidden', 'false');
    };
    const close = () => {
      panel?.classList.add('translate-x-full');
      overlay?.classList.add('opacity-0', 'pointer-events-none');
      panel?.setAttribute('aria-hidden', 'true');
    };
    document.querySelectorAll<HTMLElement>('.compass-pt').forEach((b) => {
      const go = () => { const i = parseInt(b.dataset.i || '0', 10); if (data[i]) open(data[i]); };
      b.addEventListener('click', go);
      b.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); go(); } });
    });
    document.getElementById('compassClose')?.addEventListener('click', close);
    overlay?.addEventListener('click', close);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
  </script>
</section>
