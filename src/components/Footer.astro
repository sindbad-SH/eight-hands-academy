---
import TopoTexture from './TopoTexture.astro';
import { withBase, SOCIAL, CONTACT } from '../data/site';

const quickLinks = [
  ['Events & Gatherings', '/community/events'],
  ['Summer Academy', '/community/summer-academy'],
  ['Community Impact', '/community/impact'],
  ['Alumni', '/community/alumni'],
];
const engage = [
  ['Visit the Qi-House', '/admissions#visit'],
  ['Instructor Development', '/community/instructor-development'],
  ['Governance', '/about/governance'],
];
---

<footer class="bg-navy text-stone/80 relative overflow-hidden">
  <TopoTexture id="topo-footer" />
  <div class="container-content relative z-10 py-16 grid gap-12 md:grid-cols-2 lg:grid-cols-4">
    <div>
      <img src={withBase('/img/logo.png')} alt="Eight Hands emblem" class="h-14 w-auto mb-3" />
      <div class="font-display text-2xl text-stone">Eight Hands</div>
      <div class="eyebrow !text-gold mt-1">Martial Arts Academy</div>
      <p class="mt-4 text-sm leading-relaxed text-stone/70 max-w-xs">
        A Martial Arts Education in Self-Governance.
      </p>
    </div>

    <div>
      <h3 class="eyebrow !text-stone/60 mb-4">Quick Links</h3>
      <ul class="space-y-2 text-sm">
        {quickLinks.map(([label, href]) => (
          <li><a href={withBase(href)} class="hover:text-gold transition-colors">{label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="eyebrow !text-stone/60 mb-4">Engagement</h3>
      <ul class="space-y-2 text-sm">
        {engage.map(([label, href]) => (
          <li><a href={withBase(href)} class="hover:text-gold transition-colors">{label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="eyebrow !text-stone/60 mb-4">Contact</h3>
      <address class="not-italic text-sm space-y-2 text-stone/70">
        <p>{CONTACT.cityState}</p>
        <p><a href={CONTACT.mapUrl} target="_blank" rel="noopener" class="hover:text-gold transition-colors">View on Google Maps →</a></p>
        <p><a href={`mailto:${CONTACT.email}`} class="hover:text-gold transition-colors">{CONTACT.email}</a></p>
      </address>
      <div class="mt-5 flex gap-3">
        <a href={SOCIAL.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="w-9 h-9 rounded-full border border-stone/25 flex items-center justify-center text-stone/70 hover:text-navy hover:bg-gold hover:border-gold transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M13.5 9.5H15V7h-1.7C11.5 7 10.6 8 10.6 9.7V11H9v2.5h1.6V21h2.6v-7.5h1.9l.3-2.5h-2.2V9.9c0-.3.1-.4.5-.4z"/></svg>
        </a>
        <a href={SOCIAL.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="w-9 h-9 rounded-full border border-stone/25 flex items-center justify-center text-stone/70 hover:text-navy hover:bg-gold hover:border-gold transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="4" y="4" width="16" height="16" rx="4.5"/><circle cx="12" cy="12" r="3.3"/><circle cx="16.6" cy="7.4" r="1" fill="currentColor" stroke="none"/></svg>
        </a>
        <a href={SOCIAL.tiktok} target="_blank" rel="noopener" aria-label="TikTok" class="w-9 h-9 rounded-full border border-stone/25 flex items-center justify-center text-stone/70 hover:text-navy hover:bg-gold hover:border-gold transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M14.2 3.5c.3 2 1.6 3.5 3.6 3.7v2.4c-1.2 0-2.4-.4-3.5-1.1v5.4c0 2.7-2.1 4.7-4.7 4.7s-4.6-2-4.6-4.6 2-4.7 4.6-4.7c.3 0 .6 0 .9.1v2.5c-.3-.1-.6-.2-.9-.2-1.3 0-2.2 1-2.2 2.3s1 2.3 2.3 2.3 2.3-1 2.3-2.4V3.5h2.7z"/></svg>
        </a>
        <a href={SOCIAL.yelp} target="_blank" rel="noopener" aria-label="Yelp" class="w-9 h-9 rounded-full border border-stone/25 flex items-center justify-center text-stone/70 hover:text-navy hover:bg-gold hover:border-gold transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3l2.5 5.7 6 .5-4.5 3.9 1.4 5.9L12 16.8 6.6 19l1.4-5.9L3.5 9.2l6-.5L12 3z"/></svg>
        </a>
      </div>
    </div>
  </div>

  <div class="border-t border-stone/10 relative z-10">
    <div class="container-content py-5 flex flex-col sm:flex-row justify-between gap-2 text-xs text-stone/50">
      <p>&copy; {new Date().getFullYear()} Eight Hands Martial Arts Academy · The Qi-House</p>
      <p>A Martial Arts Education in Self-Governance.</p>
    </div>
  </div>
</footer>
