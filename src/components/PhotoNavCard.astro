---
// Photo-button nav card — a full-bleed image with a dark legibility scrim and an uppercase title overlaid
// bottom-left; the whole card links to a sub-page. Mirrors the reference's About "hub" grid (image cards to
// Director's Welcome / Ethos / Founder &c.). Hover: image scales up inside the clipped frame + scrim deepens.
interface Props {
  label: string;
  href: string;
  alt: string; // dimensioned, intent-annotated placeholder
  center?: boolean; // true = title centered with an even scrim (the reference's Admissions hub); default = bottom-left (About hub)
}
import { withBase } from '../data/site';
const { label, href, alt, center = false } = Astro.props;
---
<a href={withBase(href)} class="group relative block aspect-[4/3] overflow-hidden bg-navy">
  <div class="ph absolute inset-0 !rounded-none !border-0 !text-[10px] transition-transform duration-500 ease-out group-hover:scale-105">
    {alt}
  </div>
  <div class:list={['absolute inset-0 transition-opacity duration-300', center ? 'bg-navy/45 group-hover:bg-navy/55' : 'bg-gradient-to-t from-navy/85 via-navy/25 to-transparent group-hover:from-navy/90']}></div>
  <h3
    class:list={[
      'absolute m-0 text-stone font-accent font-semibold uppercase tracking-[0.06em] leading-tight text-lg lg:text-xl',
      center ? 'inset-x-4 bottom-0 top-0 flex items-center justify-center text-center' : 'left-5 right-4 bottom-4',
    ]}
  >
    {label}
  </h3>
</a>
