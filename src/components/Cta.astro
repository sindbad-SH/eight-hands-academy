---
import { BOOKING_URL } from '../data/site';
interface Props {
  title?: string;
  text?: string;
}
const {
  title = 'Schedule your assessment.',
  text = 'Admission is a recommendation, not a sale. We begin with an assessment — a conversation to understand your goals and prescribe the right developmental path.',
} = Astro.props;
---
<section class="bg-navy text-stone">
  <div class="container-content py-section text-center reveal">
    <h2 class="text-3xl lg:text-4xl text-stone mb-5">{title}</h2>
    <p class="text-stone/80 max-w-xl mx-auto mb-9">{text}</p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href={BOOKING_URL} target="_blank" rel="noopener" class="btn-accent">Schedule an Assessment</a>
      <a href={BOOKING_URL} target="_blank" rel="noopener" class="btn-ghost !border-stone/40 !text-stone hover:!bg-stone hover:!text-navy">Book a Visit</a>
    </div>
  </div>
</section>
