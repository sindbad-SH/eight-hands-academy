---
interface Props {
  title?: string;
  text?: string;
}
const {
  title = 'Begin your inquiry.',
  text = 'An education that would still make sense if martial arts were removed and education remained.',
} = Astro.props;
---
<section class="bg-navy text-stone">
  <div class="container-content py-section text-center reveal">
    <h2 class="text-3xl lg:text-4xl text-stone mb-5">{title}</h2>
    <p class="text-stone/80 max-w-xl mx-auto mb-9">{text}</p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/admissions" class="btn-accent">Begin Your Inquiry</a>
      <a href="/admissions#visit" class="btn-ghost !border-stone/40 !text-stone hover:!bg-stone hover:!text-navy">Schedule a Visit</a>
    </div>
  </div>
</section>
