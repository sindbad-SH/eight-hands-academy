---
// "Development With Direction" — replaces the homepage CohortConstellation ("the four circles") per client
// spec (Jeanette, 2026-06-06 21:02). Two-column: LEFT title + subtitle + 4 stage cards (Observe → Practice →
// Integrate → Contribute) that expand on hover/tap; RIGHT a 16:9 rounded image panel that crossfades to the
// active stage's image. Navy/gold/white, red hover accents. Real photography slots (no stock/AI per her note).
import TopoTexture from './TopoTexture.astro';
import { withBase } from '../data/site';

const stages = [
  { n: 'Observe', href: '/learning/observe', short: 'Awareness creates possibility.', long: 'Students learn to recognize patterns, understand themselves, and develop the awareness necessary for meaningful growth.', img: '[IMAGE — student receiving instruction during a private lesson · 16:9 · 1280×720px · real Eight Hands photo]', icon: 'eye' },
  { n: 'Practice', href: '/learning/practice', short: 'Action develops capability.', long: 'Through consistent repetition and guided application, students transform knowledge into skill.', img: '[IMAGE — students actively training in class · 16:9 · 1280×720px · real photo]', icon: 'needle' },
  { n: 'Integrate', href: '/learning/integrate', short: 'Consistency transforms knowledge into character.', long: 'Physical, mental, and emotional skills begin working together as a unified system.', img: '[IMAGE — student demonstrating leadership while training · 16:9 · 1280×720px · real photo]', icon: 'geo' },
  { n: 'Contribute', href: '/learning/contribute', short: 'Development becomes service.', long: 'Students learn to apply their growth in ways that positively influence family, community, and future generations.', img: '[IMAGE — senior student mentoring younger students · 16:9 · 1280×720px · real photo]', icon: 'laurel' },
];
---
<section class="bg-navy text-stone relative overflow-hidden">
  <TopoTexture id="topo-dwd" />
  <div class="container-content relative z-10 py-section grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
    <!-- LEFT: title + subtitle + 4 stage cards -->
    <div>
      <div class="reveal mb-8">
        <h2 class="text-3xl lg:text-4xl text-stone mb-4">Development With Direction</h2>
        <p class="text-stone/75 font-display italic text-lg leading-relaxed">The Compass of Self-Governance guides students in developing mind, body, and spirit through purposeful practice, individualized education, and personal responsibility.</p>
      </div>
      <div class="space-y-3 reveal">
        {stages.map((s, i) => (
          <a href={withBase(s.href)} class="dwd-card group block w-full text-left border border-stone/15 bg-navy/40 px-5 py-4 rounded-[10px] transition-all duration-[250ms] hover:-translate-y-1.5 hover:border-gold/50" data-stage={i} aria-label={`${s.n} — learn more`}>
            <div class="flex items-center gap-4">
              <span class="dwd-icon w-10 h-10 border border-gold/50 rounded-[8px] flex items-center justify-center text-gold shrink-0 transition-transform duration-[250ms]">
                {s.icon === 'eye' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z" /><circle cx="12" cy="12" r="3" /></svg>}
                {s.icon === 'needle' && <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="12,2 14.5,12 12,22 9.5,12" /></svg>}
                {s.icon === 'geo' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="9" cy="12" r="6" /><circle cx="15" cy="12" r="6" /></svg>}
                {s.icon === 'laurel' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M7 3c-3 4-2 12 5 18M17 3c3 4 2 12-5 18M12 21v-7" /></svg>}
              </span>
              <div class="flex-1">
                <div class="flex items-center gap-3">
                  <span class="dwd-accent block h-px w-5 bg-gold transition-all duration-[250ms]"></span>
                  <span class="font-accent uppercase tracking-[0.14em] text-sm text-stone">{s.n}</span>
                </div>
                <p class="text-stone/70 text-sm mt-1">{s.short}</p>
              </div>
            </div>
            <p class="dwd-long overflow-hidden max-h-0 opacity-0 text-stone/70 text-sm leading-relaxed pl-14 transition-all duration-300">{s.long}</p>
            <span class="block pl-14 mt-2 font-accent text-[11px] uppercase tracking-[0.16em] text-gold/80 group-hover:text-gold transition-colors">Explore →</span>
          </a>
        ))}
      </div>
    </div>

    <!-- RIGHT: rotating 16:9 image panel (crossfades to the active stage) -->
    <div class="reveal">
      <div class="relative aspect-video rounded-[16px] overflow-hidden shadow-2xl">
        {stages.map((s, i) => (
          <div class="dwd-img ph absolute inset-0 !rounded-[16px] !border-0 !text-[10px] transition-opacity duration-300" data-stage={i} style={i === 0 ? 'opacity:1' : 'opacity:0'}>{s.img}</div>
        ))}
      </div>
    </div>
  </div>

  <script>
    const cards = [...document.querySelectorAll<HTMLElement>('.dwd-card')];
    const imgs = [...document.querySelectorAll<HTMLElement>('.dwd-img')];
    const setActive = (n: number) => {
      cards.forEach((c, i) => {
        const on = i === n;
        const long = c.querySelector<HTMLElement>('.dwd-long');
        const icon = c.querySelector<HTMLElement>('.dwd-icon');
        const accent = c.querySelector<HTMLElement>('.dwd-accent');
        c.classList.toggle('border-gold/50', on);
        if (long) { long.style.maxHeight = on ? '8rem' : '0'; long.style.opacity = on ? '1' : '0'; long.style.marginTop = on ? '0.75rem' : '0'; }
        if (icon) icon.style.transform = on ? 'scale(1.05)' : 'scale(1)';
        if (accent) accent.style.width = on ? '2rem' : '1.25rem';
      });
      imgs.forEach((im, i) => { im.style.opacity = i === n ? '1' : '0'; });
    };
    cards.forEach((c, i) => {
      c.addEventListener('mouseenter', () => setActive(i));
      c.addEventListener('click', () => setActive(i));
      c.addEventListener('focus', () => setActive(i));
    });
    setActive(0);
  </script>
</section>
