---
// PART: "Peel Hero" (teardown-motion.md §1) — COMPOSITION (measured from Aiglon @1920):
//   • Photo panel is INSET, not full-bleed: left navy gutter ~25%, right navy sliver ~4%,
//     navy band above (~40px) and below (~dots) the photo. Panel ≈ 71% vw wide, offset right.
//   • Wordmark anchored in the LEFT gutter (~3%), vertically ~centered on the panel; the red
//     highlight box crosses INTO the photo's left edge.
//   • Dots sit in the navy BELOW the photo, centered.
//   • Motion: 9-ish stacked slides, 5s autoplay, outgoing peels translateX -100% (0.5s ease);
//     rotating word slides in (x+opacity 0.5s) inside the red box.
const SLIDE_COUNT = 5;
const words = ['Responsibility', 'Participation', 'Discernment', 'Stewardship', 'Awareness', 'Presence', 'Character'];
const slides = Array.from({ length: SLIDE_COUNT }, (_, i) => i);
---
<section class="relative bg-navy overflow-hidden h-[480px] sm:h-[580px] lg:h-[700px]">
  <!-- Photo panel (inset, offset right). Peel slides clipped here. -->
  <div
    id="peel"
    data-words={JSON.stringify(words)}
    class="absolute z-10 overflow-hidden top-8 bottom-20 left-[4%] right-[4%] lg:left-[25%] lg:top-10 lg:bottom-24"
  >
    {slides.map((i) => (
      <div class="peel-slide absolute inset-0 will-change-transform" data-i={i}>
        <div class="absolute inset-0 bg-gradient-to-br from-navy-700 to-navy flex items-center justify-center">
          <span class="font-display leading-none text-stone/[0.06] select-none absolute text-[24vw] lg:text-[14rem]">{i + 1}</span>
          <p class="relative max-w-xs text-center text-[11px] italic text-stone/45 border border-dashed border-stone/25 rounded-sm px-4 py-3">
            [IMAGE — hero slide {i + 1} · fills panel ≈1400×660px (≈17:8 / 2.12:1), supply 2× (≈2800×1320) · candid mentorship / reflection / community, never combat]
          </p>
        </div>
      </div>
    ))}
  </div>

  <!-- Wordmark overlay: left gutter, vertically centered on the panel, red box crosses into photo -->
  <div class="absolute z-30 pointer-events-none flex flex-col justify-center top-8 bottom-20 left-[6%] right-[4%] lg:top-10 lg:bottom-24 lg:left-[3%] lg:right-[6%]">
    <p class="eyebrow !text-gold mb-3 lg:mb-4">8 Hands Martial Arts Academy · The Qi-House</p>
    <h1 class="font-display text-stone font-semibold leading-[0.95] text-3xl sm:text-5xl lg:text-7xl drop-shadow-sm">An Education in</h1>
    <div class="mt-2 lg:mt-3 lg:ml-[12%]">
      <span id="peelWord" class="inline-block bg-red text-stone font-display font-semibold leading-none px-3 py-1.5 lg:px-4 text-3xl sm:text-5xl lg:text-6xl shadow-md">Responsibility</span>
    </div>
  </div>

  <!-- Dots: navy band below the photo, centered -->
  <div id="peelDots" class="absolute z-30 bottom-7 lg:bottom-9 left-0 right-0 flex justify-center gap-2.5">
    {slides.map((i) => (
      <button class="peel-dot h-2.5 w-2.5 rounded-full bg-stone/40 transition-all duration-300" data-i={i} aria-label={`Go to slide ${i + 1}`}></button>
    ))}
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  const root = document.getElementById('peel');
  if (root) {
    const words = JSON.parse(root.dataset.words || '[]');
    const slides = [...root.querySelectorAll('.peel-slide')];
    const dots = [...document.querySelectorAll('.peel-dot')];
    const wordEl = document.getElementById('peelWord');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let cur = 0;
    let timer;

    const initSlides = () =>
      slides.forEach((s, i) => gsap.set(s, { xPercent: 0, autoAlpha: i === 0 ? 1 : 0, zIndex: i === 0 ? 20 : 10 }));

    const updateDots = () =>
      dots.forEach((d, i) => {
        const on = i === cur;
        d.classList.toggle('bg-gold', on);
        d.classList.toggle('bg-stone/40', !on);
        d.style.width = on ? '1.5rem' : '';
      });

    const go = (next) => {
      if (next === cur) return;
      const out = slides[cur];
      const inc = slides[next];
      gsap.set(inc, { xPercent: 0, autoAlpha: 1, zIndex: 10 });
      gsap.set(out, { zIndex: 20 });
      wordEl.textContent = words[next % words.length];
      if (reduce) {
        gsap.set(out, { autoAlpha: 0 });
        gsap.set(inc, { zIndex: 20 });
      } else {
        gsap.fromTo(wordEl, { x: -24, autoAlpha: 0 }, { x: 0, autoAlpha: 1, duration: 0.5, ease: 'power2.out' });
        gsap.to(out, {
          xPercent: -100,
          duration: 0.5,
          ease: 'power2.inOut',
          onComplete: () => {
            gsap.set(out, { autoAlpha: 0, xPercent: 0, zIndex: 10 });
            gsap.set(inc, { zIndex: 20 });
          },
        });
      }
      cur = next;
      updateDots();
    };

    const start = () => {
      clearInterval(timer);
      timer = setInterval(() => go((cur + 1) % slides.length), 5000);
    };

    initSlides();
    updateDots();
    dots.forEach((d, i) => d.addEventListener('click', () => { go(i); start(); }));
    start();
  }
</script>
