---
// Subtle background motif for navy sections. Per client (2026-06-08): the old wavy "topo" lines were
// removed; this is a very thin, very subtle BAMBOO-grove motif (Eastern-philosophy nod, drawn from the
// bamboo seen in the studio photos) — quiet texture to break up the navy without distracting.
// currentColor + low opacity, pointer-events-none. Used on the homepage navy sections (NOT the footer).
interface Props {
  id?: string;
  class?: string;
}
const { id = 'topo', class: cls = 'text-stone/[0.06]' } = Astro.props;
---
<svg
  class:list={['pointer-events-none absolute inset-0 h-full w-full', cls]}
  aria-hidden="true"
  preserveAspectRatio="xMidYMid slice"
>
  <defs>
    <pattern id={id} width="440" height="480" patternUnits="userSpaceOnUse" patternTransform="rotate(-5)">
      <g fill="none" stroke="currentColor" stroke-linecap="round">
        <!-- bamboo culm A -->
        <path d="M96 500 L96 -20" stroke-width="1.1" />
        <path d="M88 400 H104 M88 312 H104 M88 224 H104 M88 136 H104 M88 48 H104" stroke-width="0.8" />
        <path d="M96 232 q30 -6 58 -30 q-34 16 -58 12" stroke-width="0.9" />
        <path d="M96 232 q28 10 54 4 q-30 8 -54 -2" stroke-width="0.9" />
        <path d="M96 150 q-28 -6 -52 -28 q30 16 52 10" stroke-width="0.9" />
        <!-- bamboo culm B (offset, lighter) -->
        <path d="M316 500 L316 -20" stroke-width="0.9" opacity="0.7" />
        <path d="M309 360 H323 M309 272 H323 M309 184 H323 M309 96 H323" stroke-width="0.7" opacity="0.7" />
        <path d="M316 300 q-28 -6 -52 -28 q30 16 52 10" stroke-width="0.85" opacity="0.7" />
        <path d="M316 208 q28 -6 52 -26 q-30 14 -52 8" stroke-width="0.85" opacity="0.7" />
      </g>
    </pattern>
  </defs>
  <rect width="100%" height="100%" fill={`url(#${id})`} />
</svg>
