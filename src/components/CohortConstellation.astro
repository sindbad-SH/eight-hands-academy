---
// PART: "Cohort Constellation" (teardown-motion.md §5) — developmental cohorts as connected dashed-outline
// circles of varying size, linked by a dashed spiral path. Each circle POPS IN one-by-one (staggered,
// one-shot) as the section scrolls into view — mirrors the reference (like the stat-map flags). Sits on navy.
const cohorts = [
  { label: 'Wonder &\nDiscovery', href: '/learning#wonder', size: 122, x: 12, y: 56 },
  { label: 'Exploration', href: '/learning#exploration', size: 156, x: 33, y: 18 },
  { label: 'Integration', href: '/learning#integration', size: 200, x: 60, y: 47 },
  { label: 'Stewardship', href: '/learning#stewardship', size: 132, x: 86, y: 16 },
];
---
<div class="relative h-[380px] sm:h-[460px] overflow-hidden" data-constellation>
  <svg class="constellation-path absolute inset-0 w-full h-full text-gold/45" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
    <path d="M12,58 C22,44 27,24 33,20 C47,12 50,42 60,49 C75,58 82,28 86,18" fill="none" stroke="currentColor" stroke-width="0.35" stroke-dasharray="1.4 1.4" />
  </svg>
  {cohorts.map((c, i) => (
    <a
      href={c.href}
      class="absolute block"
      style={`left:${c.x}%; top:${c.y}%; transform:translate(-50%,-50%);`}
    >
      <span
        class="constellation-node group rounded-full border-2 border-dashed border-gold bg-navy/40 hover:bg-navy/10 flex items-center justify-center text-center p-3"
        style={`width:${c.size}px; height:${c.size}px; transition-delay:${i * 160}ms;`}
      >
        <span class="font-accent uppercase tracking-[0.12em] text-gold leading-tight whitespace-pre-line text-[11px] sm:text-xs">{c.label}</span>
      </span>
    </a>
  ))}
</div>

<style>
  /* Each circle starts small + invisible; the staggered transition-delay (set inline per circle) makes
     them pop in one-by-one when the container gets `.is-constellation-in`. */
  .constellation-node {
    opacity: 0;
    transform: scale(0.5);
    transition:
      opacity 0.45s ease,
      transform 0.55s cubic-bezier(0.2, 0.85, 0.3, 1.25),
      background-color 0.2s ease;
  }
  .is-constellation-in .constellation-node {
    opacity: 1;
    transform: scale(1);
  }
  .constellation-path {
    opacity: 0;
    transition: opacity 0.8s ease 0.15s;
  }
  .is-constellation-in .constellation-path {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .constellation-node,
    .constellation-path {
      opacity: 1;
      transform: scale(1);
      transition: none;
    }
  }
</style>

<script>
  // One-shot staggered reveal: when the constellation scrolls into view, pop the circles in sequence (then stop).
  const el = document.querySelector('[data-constellation]');
  if (el) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-constellation-in');
            io.unobserve(e.target);
          }
        });
      },
      { rootMargin: '0px 0px -15% 0px' }
    );
    io.observe(el);
  }
</script>
